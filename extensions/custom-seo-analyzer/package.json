{
  "name": "directus-extension-custom-seo-analyzer",
  "description": "Custom Yoast/RankMath style SEO Analyzer Interface for Directus",
  "version": "1.0.0",
  "type": "module",
  "directus:extension": {
    "host": "^10.10.0 || ^11.0.0 || ^12.0.0 || ^13.0.0",
    "type": "bundle",
    "path": {
      "app": "dist/app.mjs",
      "api": "dist/api.mjs"
    },
    "entries": [
      {
        "type": "interface",
        "name": "custom-seo-analyzer",
        "source": "src/interface.ts"
      }
    ]
  },
  "files": ["dist"],
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^13.0.4",
    "vue": "^3.5.13"
  }
}
