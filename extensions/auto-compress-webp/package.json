{
  "name": "directus-extension-auto-compress-webp",
  "version": "1.0.0",
  "type": "module",
  "description": "Directus hook to automatically compress and convert uploaded images to WebP",
  "directus:extension": {
    "type": "hook",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^10.10.0 || ^11.0.0 || ^12.0.0 || ^13.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^13.0.4",
    "typescript": "^5.0.0"
  }
}
