---
import type { Package, ActivityType } from "../types/directus";
import { getAssetUrl } from "../lib/directus";
import { formatPrice } from "../lib/utils";
import WaButton from "./WaButton.astro";

interface Props {
  pkg: Package;
  destinationName: string;
  destinationSlug: string;
  startingPrice: number | null;
  packageActivityTypes: ActivityType[];
  waNumber: string;
}

const { pkg, destinationName, destinationSlug, startingPrice, packageActivityTypes, waNumber } = Astro.props;
---

<!-- ===== HERO ===== -->
<section class="relative min-h-[420px] max-lg:min-h-[360px] flex items-center overflow-hidden bg-navy-900">
  {pkg.gallery?.[0] ? (
    <img src={getAssetUrl(pkg.gallery[0], { width: 1440, height: 600, format: "webp", quality: 85 })} alt={pkg.name} class="absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" decoding="async" />
  ) : (
    <div class="absolute inset-0 bg-gradient-to-br from-navy-800 via-navy-900 to-navy-950 flex items-center justify-center">
      <div class="text-center text-navy-400"><i class="fa-regular fa-image text-6xl"></i><p class="text-sm mt-2 font-medium">No Image</p></div>
    </div>
  )}
  <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/70 to-navy-950/15"></div>
  <div class="absolute -top-16 -right-8 w-48 h-48 rounded-full bg-orange-500/10 blur-[60px]" aria-hidden="true"></div>

  <div class="wrap relative z-10 py-24 max-lg:py-16 w-full">
    {destinationName && (
      <a href={"/destinasi/" + destinationSlug} class="inline-flex items-center gap-1.5 text-white/50 hover:text-orange-400 text-xs font-medium transition-colors mb-4 no-underline">
        <i class="fa-solid fa-arrow-left text-[10px]"></i>
        <i class="fa-solid fa-location-dot text-orange-400 text-[10px] mr-0.5"></i>{destinationName}
      </a>
    )}
    <div class="max-w-[700px]">
      <h1 class="font-[family-name:var(--font-display)] text-white text-4xl max-lg:text-3xl max-md:text-2xl font-bold leading-tight">{pkg.name}</h1>
      <div class="flex flex-wrap items-center gap-3 mt-5">
        <span class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm text-white text-xs font-medium px-3 py-1.5 rounded-full">
          <i class="fa-regular fa-clock text-orange-400 text-[11px]"></i>{pkg.duration}
        </span>
        {pkg.max_participants && (
          <span class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm text-white text-xs font-medium px-3 py-1.5 rounded-full">
            <i class="fa-solid fa-user text-orange-400 text-[11px]"></i>Max {pkg.max_participants} orang
          </span>
        )}
        {startingPrice && (
          <span class="inline-flex items-center gap-1.5 bg-orange-500/20 backdrop-blur-sm text-orange-300 text-xs font-medium px-3 py-1.5 rounded-full">
            <i class="fa-solid fa-tag text-[11px]"></i>Mulai {formatPrice(startingPrice)}/org
          </span>
        )}
      </div>

      {packageActivityTypes.length > 0 && (
        <div class="flex flex-wrap items-center gap-2 mt-3.5">
          {packageActivityTypes.map((actType) => (
            <a
              href={"/cari?kegiatan=" + actType.slug}
              class="inline-flex items-center gap-1 bg-orange-500/10 border border-orange-500/20 backdrop-blur-sm text-orange-300 text-xs font-medium px-2.5 py-1 rounded-full no-underline hover:bg-orange-500/20 transition-colors"
            >
              <i class="fa-solid fa-tag text-[9px]"></i>
              {actType.name}
            </a>
          ))}
        </div>
      )}

      {pkg.description && (
        <div class="text-white/60 text-sm leading-relaxed mt-4 max-w-xl line-clamp-3" set:html={pkg.description}></div>
      )}
    </div>
  </div>
</section>

<!-- ===== QUICK CTA ===== -->
<section class="sticky top-[88px] z-20 bg-white/95 backdrop-blur-md border-b border-[--color-line]">
  <div class="wrap py-2.5">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2.5 max-sm:hidden">
        <i class="fa-regular fa-circle-check text-green-500"></i>
        <span class="text-navy-600 text-xs">Tersedia untuk {destinationName || "destinasi pilihan"}</span>
      </div>
      <div class="flex items-center gap-2.5 w-full sm:w-auto justify-between sm:justify-end">
        {startingPrice && <span class="text-navy-700 text-sm font-semibold">Mulai <strong class="text-orange-600 text-base">{formatPrice(startingPrice)}</strong>/org</span>}
        <WaButton phone={waNumber} variant="primary" message={encodeURIComponent(`Halo Voda Tour & Event, saya tertarik dengan paket ${pkg.name}.`)} class="shrink-0 text-xs px-4 py-2">Pesan</WaButton>
      </div>
    </div>
  </div>
</section>
