---
import SearchCard from "./SearchCard.astro";

// Voda Tour & Event — Hero Component
// Full-bleed hero with gradient background + SearchCard

interface Props {
  settings?: { phone?: string; whatsapp?: string };
  destinations?: { id: number; name: string; slug: string }[];
  activityTypes?: { id: number; name: string }[];
}

const { settings = {}, destinations = [], activityTypes = [] } = Astro.props;
const phone = settings.whatsapp || settings.phone || '6282112345678';
---

<section class="relative overflow-hidden">
  <img
    src="/images/beach.avif"
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    aria-hidden="true"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-[rgba(10,59,82,0.92)] via-[rgba(10,59,82,0.5)] to-[rgba(10,59,82,0.05)]" aria-hidden="true"></div>

  <div class="wrap relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-[40px] py-[80px] max-lg:py-[50px] items-center">

      <div>
        <div class="flex items-center gap-[10px]">
          <span class="block w-[22px] h-[2px] bg-orange-400 rounded-full shrink-0"></span>
          <span class="font-[family-name:var(--font-body)] font-bold tracking-[0.14em] uppercase text-[12.5px] text-orange-400 leading-none">VODA TOUR &amp; EVENT</span>
        </div>

        <h1 class="font-[family-name:var(--font-display)] text-white font-bold text-[48px] max-lg:text-[38px] max-md:text-[32px] leading-[1.15] mt-[18px]">
          Perjalanan Berkesan,<br />Momen <span class="font-[family-name:var(--font-accent)] italic font-normal text-orange-400">Tak Terlupakan</span>
        </h1>

        <p class="text-white/75 text-[15.5px] leading-relaxed max-w-[440px] mt-[14px]">
          Solusi perjalanan wisata, gathering, dan event terbaik untuk Anda dan perusahaan.
        </p>

        <div class="flex flex-wrap gap-[14px] mt-[28px]">
          <a
            href="#paket"
            class="inline-flex items-center gap-[10px] bg-orange-600 text-white rounded-[999px] px-[26px] py-[14px] font-semibold text-[14.5px] no-underline shadow-[0_14px_28px_-10px_rgba(238,125,15,0.55)] transition-all duration-[0.18s] hover:-translate-y-[2px] hover:shadow-[0_18px_34px_-10px_rgba(238,125,15,0.65)]"
          >
            Lihat Paket <i class="fa-solid fa-arrow-right"></i>
          </a>
          <a
            href={`https://wa.me/${phone}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-[10px] bg-transparent text-white border-[1.5px] border-white/40 rounded-[999px] px-[26px] py-[14px] font-semibold text-[14.5px] no-underline transition-all duration-[0.18s] hover:bg-white/10"
          >
            <i class="fa-brands fa-whatsapp"></i> Konsultasi Gratis
          </a>
        </div>
      </div>

      <div class="lg:justify-self-end w-full max-w-[420px] max-lg:max-w-full">
        <SearchCard {destinations} {activityTypes} />
      </div>

    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-[80px] bg-gradient-to-t from-[#0A3B52] to-transparent pointer-events-none" aria-hidden="true"></div>
</section>
