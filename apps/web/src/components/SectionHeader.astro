---
// Voda Tour & Event — SectionHeader Component
// Reusable section header: eyebrow + H2 + description + optional CTA

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  ctaLabel?: string;
  ctaUrl?: string;
  layout?: 'default' | 'split';
}

const { eyebrow, title, description, ctaLabel, ctaUrl, layout = 'default' } = Astro.props;
---

{
  layout === 'split' ? (
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-[14px]">
      <div>
        {eyebrow && (
          <div class="flex items-center gap-[10px]">
            <span class="font-[family-name:var(--font-body)] font-bold tracking-[0.14em] uppercase text-[12.5px] text-orange-600 leading-none">{eyebrow}</span>
          </div>
        )}
        <h2 class="font-[family-name:var(--font-display)] text-navy-900 font-bold text-[34px] max-lg:text-[28px] leading-[1.15] mt-[10px]">{title}</h2>
      </div>
      {ctaLabel && ctaUrl && (
        <a
          href={ctaUrl}
          class="inline-flex items-center gap-[8px] text-orange-600 font-semibold text-[14px] no-underline whitespace-nowrap transition-colors hover:text-orange-500 shrink-0"
        >
          {ctaLabel} <i class="fa-solid fa-arrow-right text-[12px]"></i>
        </a>
      )}
    </div>
  ) : (
    <div>
      {eyebrow && (
        <div class="flex items-center gap-[10px]">
          <span class="block w-[22px] h-[2px] bg-orange-600 rounded-full shrink-0"></span>
          <span class="font-[family-name:var(--font-body)] font-bold tracking-[0.14em] uppercase text-[12.5px] text-orange-600 leading-none">{eyebrow}</span>
        </div>
      )}
      <h2 class="font-[family-name:var(--font-display)] text-navy-900 font-bold text-[34px] max-lg:text-[28px] leading-[1.15] mt-[10px]">{title}</h2>
      {description && <p class="text-body text-[15px] leading-relaxed max-w-[600px] mt-[8px]">{description}</p>}
    </div>
  )
}
