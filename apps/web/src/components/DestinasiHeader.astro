---
// Voda Tour & Event — DestinasiHeader Component
// Hero variant untuk halaman detail destinasi
// Gradient bg + nama destinasi + region badge + deskripsi

import type { Destination } from "../types/directus";
import { getAssetUrl } from "../lib/directus";

interface Props {
  destination: Destination;
  packageCount: number;
}

const { destination: d, packageCount } = Astro.props;
const bgImage = d.image
  ? getAssetUrl(d.image, { width: 1440, height: 600, format: "webp", quality: 85 })
  : null;

const regionName =
  typeof d.region_id === "object" ? (d.region_id as any)?.name : "";
---

<section class="relative min-h-[420px] flex items-center overflow-hidden">
  <!-- Background Image + Overlay -->
  {bgImage ? (
    <img
      src={bgImage}
      alt={d.name}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
  ) : (
    <div class="absolute inset-0 bg-navy-200 flex items-center justify-center">
      <div class="text-center text-navy-400">
        <i class="fa-regular fa-image text-[56px]"></i>
        <p class="text-[14px] mt-[8px] font-medium">No Image</p>
      </div>
    </div>
  )}
  <div class="absolute inset-0 bg-gradient-to-r from-[rgba(10,59,82,0.95)] via-[rgba(10,59,82,0.7)] to-[rgba(10,59,82,0.15)]"></div>

  <!-- Content -->
  <div class="wrap relative z-10 py-[90px] max-lg:py-[60px]">
    <!-- Region Badge -->
    {regionName && (
      <span class="inline-flex items-center gap-[6px] bg-white/15 backdrop-blur-sm text-white text-[12px] font-medium px-[12px] py-[4px] rounded-full mb-[16px]">
        <i class="fa-solid fa-location-dot text-orange-500 text-[10px]"></i>
        {regionName}
      </span>
    )}

    <h1 class="font-[family-name:var(--font-display)] text-white text-[42px] max-lg:text-[30px] font-bold leading-tight max-w-[600px]">
      {d.name}
    </h1>

    {d.description && (
      <p class="text-white/80 text-[16px] max-lg:text-[14px] leading-relaxed mt-[12px] max-w-[560px]">
        {d.description}
      </p>
    )}

    <!-- Stats -->
    <div class="flex items-center gap-[24px] mt-[28px]">
      <div class="flex items-center gap-[8px] text-white/70 text-[13px]">
        <i class="fa-solid fa-box text-orange-500 text-[14px]"></i>
        <span><strong class="text-white">{packageCount}</strong> Paket Tersedia</span>
      </div>
    </div>
  </div>
</section>
