---
import type { Package } from "../types/directus";
import { getAssetUrl } from "../lib/directus";

interface Props {
  similarPackages: Package[];
  destinationName: string;
  destinationSlug: string;
}

const { similarPackages, destinationName, destinationSlug } = Astro.props;
---
<section class="py-16 max-lg:py-12"><div class="wrap">
  <div class="flex items-end justify-between mb-8">
    <div>
      <span class="text-xs font-semibold text-orange-600 uppercase tracking-widest">Paket Lainnya</span>
      <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-2xl font-bold mt-1">Destinasi {destinationName}</h2>
    </div>
    <a href={"/destinasi/" + destinationSlug} class="hidden sm:inline-flex items-center gap-1.5 text-orange-600 text-sm font-semibold no-underline hover:underline">
      Lihat Semua <i class="fa-solid fa-arrow-right text-[11px]"></i>
    </a>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {similarPackages.map((similarPkg) => (
      <a href={"/paket/" + similarPkg.slug} class="group block bg-white rounded-[var(--radius-lg)] shadow-[var(--shadow-soft)] overflow-hidden no-underline hover:shadow-[0_12px_32px_rgba(0,0,0,0.1)] transition-all duration-300 hover:-translate-y-1.5">
        <div class="aspect-video overflow-hidden bg-navy-100">
          {similarPkg.gallery?.[0] ? (
            <img src={getAssetUrl(similarPkg.gallery[0], { width: 600, height: 338, format: "webp", quality: 85 })} alt={similarPkg.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-navy-300"><i class="fa-regular fa-image text-3xl"></i></div>
          )}
        </div>
        <div class="p-5">
          <h3 class="font-[family-name:var(--font-display)] text-navy-800 text-base font-semibold group-hover:text-orange-600 transition-colors line-clamp-2">{similarPkg.name}</h3>
          <div class="flex items-center justify-between mt-2.5">
            <span class="text-navy-400 text-xs"><i class="fa-regular fa-clock mr-1"></i>{similarPkg.duration}</span>
            <span class="text-orange-600 text-xs font-semibold group-hover:translate-x-0.5 transition-transform">Detail <i class="fa-solid fa-arrow-right text-[10px]"></i></span>
          </div>
        </div>
      </a>
    ))}
  </div>
</div></section>
