---
// Voda Tour & Event — Footer Component
// Navy-900 footer with 3 columns: brand, nav, contact & social

interface Props {
  settings?: {
    site_name?: string;
    whatsapp?: string;
    phone?: string;
    email?: string;
    address?: string;
    instagram?: string;
  };
}

const { settings = {} } = Astro.props;

const s = {
  site_name: 'Voda Tour & Event',
  whatsapp: settings.whatsapp || '6282112345678',
  phone: settings.phone || '6282112345678',
  email: settings.email || 'hello@vodaevent.id',
  instagram: settings.instagram || 'vodaevent',
};

const navLinks = [
  { label: 'Beranda', url: '/' },
  { label: 'Paket Wisata', url: '/paket' },
  { label: 'Gathering & Event', url: '/gathering' },
  { label: 'Destinasi', url: '/destinasi' },
  { label: 'Tentang Kami', url: '/tentang' },
  { label: 'Kontak', url: '/kontak' },
];
---

<footer class="bg-navy-900 text-white">
  <div class="wrap py-[70px] max-lg:py-[50px]">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-[50px] max-lg:gap-[34px]">

      <!-- Col 1: Brand -->
      <div>
        <a href="/" class="flex items-center gap-[10px] no-underline mb-[18px]">
          <div class="w-[38px] h-[38px] bg-white/20 rounded-[--radius-sm] flex items-center justify-center text-white text-[18px] -rotate-[8deg]">
            <i class="fa-solid fa-plane"></i>
          </div>
          <div class="leading-tight">
            <div class="font-[family-name:var(--font-display)] font-bold text-[20px] text-white leading-none">VODA</div>
            <div class="text-[10px] font-bold tracking-[0.25em] text-orange-500 leading-tight">TOUR &amp; EVENT</div>
          </div>
        </a>
        <p class="text-white/60 text-[14px] leading-relaxed max-w-[300px]">
          Perjalanan berkesan, momen tak terlupakan. Spesialis private tour &amp; corporate event sejak 2024.
        </p>
      </div>

      <!-- Col 2: Navigasi -->
      <div>
        <h4 class="font-[family-name:var(--font-body)] font-semibold text-white text-[14px] tracking-[0.1em] uppercase mb-[18px]">Navigasi</h4>
        <ul class="space-y-[10px] list-none p-0 m-0">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.url}
                class="text-white/60 text-[14px] no-underline transition-colors hover:text-orange-500"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Kontak & Sosial -->
      <div>
        <h4 class="font-[family-name:var(--font-body)] font-semibold text-white text-[14px] tracking-[0.1em] uppercase mb-[18px]">Kontak</h4>
        <ul class="space-y-[12px] list-none p-0 m-0">
          <li>
            <a href={`https://wa.me/${s.whatsapp}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-[10px] text-white/60 text-[14px] no-underline transition-colors hover:text-orange-500">
              <i class="fa-brands fa-whatsapp w-[16px] text-orange-500"></i>
              {s.whatsapp}
            </a>
          </li>
          <li>
            <a href={`tel:${s.phone}`} class="flex items-center gap-[10px] text-white/60 text-[14px] no-underline transition-colors hover:text-orange-500">
              <i class="fa-solid fa-phone w-[16px] text-orange-500"></i>
              {s.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${s.email}`} class="flex items-center gap-[10px] text-white/60 text-[14px] no-underline transition-colors hover:text-orange-500">
              <i class="fa-solid fa-envelope w-[16px] text-orange-500"></i>
              {s.email}
            </a>
          </li>
          <li>
            <a href={`https://instagram.com/${s.instagram}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-[10px] text-white/60 text-[14px] no-underline transition-colors hover:text-orange-500">
              <i class="fa-brands fa-instagram w-[16px] text-orange-500"></i>
              @{s.instagram}
            </a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Copyright bar -->
  <div class="border-t border-white/10">
    <div class="wrap py-[18px] flex flex-col sm:flex-row items-center justify-between gap-[8px]">
      <p class="text-white/40 text-[12px] m-0">
        &copy; {new Date().getFullYear()} {s.site_name}. All rights reserved.
      </p>
      <p class="text-white/30 text-[11px] m-0">
        Designed with <i class="fa-solid fa-heart text-orange-500 text-[10px]"></i> for unforgettable moments
      </p>
    </div>
  </div>
</footer>
