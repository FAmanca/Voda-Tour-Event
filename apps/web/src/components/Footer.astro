---
// Voda Tour & Event — Footer Component
// Navy-900 footer with 4 columns: brand, nav, contact, address & social

interface Props {
  settings?: {
    site_name?: string;
    email?: string;
    phone?: string;
    whatsapp?: string;
    wa_number?: string;
    instagram?: string;
    facebook?: string;
    youtube?: string;
    tiktok?: string;
    threads?: string;
    x?: string;
    address?: string;
  };
}

const { settings = {} } = Astro.props;

const s = {
  site_name: settings.site_name || 'Voda Tour & Event',
  email: settings.email || 'hello@vodatrip.id',
  phone: settings.phone || '6282112345678',
  wa_number: settings.wa_number || settings.whatsapp || '6282112345678',
  instagram: settings.instagram || 'voda.event',
  facebook: settings.facebook || 'voda.event',
  youtube: settings.youtube || '@vodatrip',
  tiktok: settings.tiktok || '@voda.event',
  threads: settings.threads || '@voda.event',
  x: settings.x || 'voda_event',
  address: settings.address || 'Ruko Travelindo, Jl. Pariwisata Raya No. 42, Kota Baru, 12345',
};

const navLinks = [
  { label: 'Beranda', url: '/' },
  { label: 'Paket Wisata', url: '/paket' },
  { label: 'Gathering & Event', url: '/gathering' },
  { label: 'Destinasi', url: '/destinasi' },
  { label: 'Tentang Kami', url: '/tentang' },
  { label: 'Kontak', url: '/kontak' },
];
---

<footer aria-label="Footer" class="bg-navy-900 text-white border-t border-white/5 py-5">
  <div class="wrap pt-[120px] pb-[80px] max-lg:pt-[80px] max-lg:pb-[50px]">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-[40px] max-lg:gap-[30px]">

      <!-- Col 1: Brand -->
      <div class="flex flex-col gap-[20px]">
        <div class="inline-block">
          <a href="/" class="inline-flex items-center bg-white rounded-[var(--radius-md)] px-[14px] py-[8px] shadow-[0_4px_12px_rgba(255,255,255,0.05)] border border-white/10 hover:opacity-95 transition-opacity">
            <img src="/images/VodaTravelIcon-small.webp" width="60" height="40" alt="Voda Tour & Event" class="h-[40px] w-auto object-contain" />
          </a>
        </div>
        <p class="text-white/60 text-[13.5px] leading-relaxed max-w-[280px] m-0">
          Perjalanan berkesan, momen tak terlupakan. Spesialis private tour &amp; corporate event terpercaya sejak 2024.
        </p>
        <!-- Social Icons Row -->
        <!-- <div class="flex flex-wrap gap-[10px]">
          <a href={`https://facebook.com/${s.facebook}`} target="_blank" rel="noopener noreferrer" class="w-[36px] h-[36px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/70 hover:bg-[#1877F2] hover:text-white hover:border-[#1877F2] hover:-translate-y-[2px] transition-all duration-[0.2s]" aria-label="Facebook">
            <i class="fa-brands fa-facebook-f text-[15px]"></i>
          </a>
          <a href={`https://youtube.com/${s.youtube}`} target="_blank" rel="noopener noreferrer" class="w-[36px] h-[36px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/70 hover:bg-[#FF0000] hover:text-white hover:border-[#FF0000] hover:-translate-y-[2px] transition-all duration-[0.2s]" aria-label="YouTube">
            <i class="fa-brands fa-youtube text-[15px]"></i>
          </a>
          <a href={`https://instagram.com/${s.instagram}`} target="_blank" rel="noopener noreferrer" class="w-[36px] h-[36px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/70 hover:bg-[#E4405F] hover:text-white hover:border-[#E4405F] hover:-translate-y-[2px] transition-all duration-[0.2s]" aria-label="Instagram">
            <i class="fa-brands fa-instagram text-[16px]"></i>
          </a>
          <a href={`https://tiktok.com/${s.tiktok}`} target="_blank" rel="noopener noreferrer" class="w-[36px] h-[36px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/70 hover:bg-[#000000] hover:text-white hover:border-white hover:-translate-y-[2px] transition-all duration-[0.2s]" aria-label="TikTok">
            <i class="fa-brands fa-tiktok text-[15px]"></i>
          </a>
          <a href={`https://threads.net/${s.threads}`} target="_blank" rel="noopener noreferrer" class="w-[36px] h-[36px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/70 hover:bg-[#000000] hover:text-white hover:border-white hover:-translate-y-[2px] transition-all duration-[0.2s]" aria-label="Threads">
            <i class="fa-brands fa-threads text-[16px]"></i>
          </a>
          <a href={`https://x.com/${s.x}`} target="_blank" rel="noopener noreferrer" class="w-[36px] h-[36px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/70 hover:bg-[#000000] hover:text-white hover:border-white hover:-translate-y-[2px] transition-all duration-[0.2s]" aria-label="X">
            <i class="fa-brands fa-x-twitter text-[15px]"></i>
          </a>
        </div> -->
      </div>

      <!-- Col 2: Navigasi -->
      <div>
        <p class="font-[family-name:var(--font-body)] font-semibold text-white text-[13px] tracking-[0.15em] uppercase pb-[8px] border-b border-orange-500/30 inline-block mb-[20px]">Navigasi</p>
        <ul class="space-y-[10px] list-none p-0 m-0">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.url}
                class="text-white/70 text-[13.5px] no-underline transition-all duration-[0.2s] hover:text-orange-400 hover:pl-[4px] inline-block"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Kontak -->
      <div>
        <p class="font-[family-name:var(--font-body)] font-semibold text-white text-[13px] tracking-[0.15em] uppercase pb-[8px] border-b border-orange-500/30 inline-block mb-[20px]">Hubungi Kami</p>
        <ul class="space-y-[14px] list-none p-0 m-0">
          <li>
            <a href={`https://wa.me/${s.wa_number}?text=Halo%20Voda%20Tour%20%26%20Event%2C%20saya%20ingin%20tahu%20lebih%20lanjut%20mengenai%20layanan%20Anda.`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-[12px] text-white/70 text-[13.5px] no-underline transition-colors hover:text-orange-400 group">
              <div class="w-[32px] h-[32px] rounded-full bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-500 shrink-0 text-[15px] group-hover:bg-orange-500 group-hover:text-white transition-colors duration-[0.2s]">
                <i class="fa-brands fa-whatsapp"></i>
              </div>
              <span class="truncate">{s.wa_number}</span>
            </a>
          </li>
          <li>
            <a href={`mailto:${s.email}`} class="flex items-center gap-[12px] text-white/70 text-[13.5px] no-underline transition-colors hover:text-orange-400 group">
              <div class="w-[32px] h-[32px] rounded-full bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-500 shrink-0 text-[14px] group-hover:bg-orange-500 group-hover:text-white transition-colors duration-[0.2s]">
                <i class="fa-solid fa-envelope"></i>
              </div>
              <span class="truncate">{s.email}</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 4: Kantor & Alamat -->
      <div>
        <p class="font-[family-name:var(--font-body)] font-semibold text-white text-[13px] tracking-[0.15em] uppercase pb-[8px] border-b border-orange-500/30 inline-block mb-[20px]">Kantor Kami</p>
        <div class="flex items-start gap-[12px] text-white/70 text-[13.5px]">
          <div class="w-[32px] h-[32px] rounded-full bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-500 shrink-0 text-[14px]">
            <i class="fa-solid fa-location-dot"></i>
          </div>
          <p class="m-0 leading-relaxed max-w-[200px]">
            {s.address}
          </p>
        </div>
      </div>

    </div>
  </div>

  <!-- Copyright bar -->
  <div class="border-t border-white/5">
    <div class="wrap py-[20px] flex flex-col sm:flex-row items-center justify-between gap-[10px]">
      <p class="text-white/60 text-[12px] m-0">
        &copy; {new Date().getFullYear()} {s.site_name}. All rights reserved.
      </p>
      <!-- <p class="text-white/30 text-[11px] m-0">
        Designed with <i class="fa-solid fa-heart text-orange-500 text-[10px]"></i> for unforgettable moments
      </p> -->
    </div>
  </div>
</footer>
