---
// Voda Tour & Event — Footer Component
// Navy-900 footer with 4 columns: brand, nav, contact, address & social

interface Props {
  settings?: {
    site_name?: string;
    whatsapp?: string;
    phone?: string;
    email?: string;
    address?: string;
    instagram?: string;
  };
}

const { settings = {} } = Astro.props;

const s = {
  site_name: settings.site_name || 'Voda Tour & Event',
  whatsapp: settings.whatsapp || '6282112345678',
  phone: settings.phone || '6282112345678',
  email: settings.email || 'hello@vodaevent.id',
  instagram: settings.instagram || 'vodaevent',
  address: settings.address || 'Bandung, Jawa Barat, Indonesia',
};

const navLinks = [
  { label: 'Beranda', url: '/' },
  { label: 'Paket Wisata', url: '/paket' },
  { label: 'Gathering & Event', url: '/gathering' },
  { label: 'Destinasi', url: '/destinasi' },
  { label: 'Tentang Kami', url: '/tentang' },
  { label: 'Kontak', url: '/kontak' },
];
---

<footer class="bg-navy-900 text-white border-t border-white/5">
  <div class="wrap py-[80px] max-lg:py-[50px]">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-[40px] max-lg:gap-[30px]">

      <!-- Col 1: Brand -->
      <div class="flex flex-col gap-[20px]">
        <div class="inline-block">
          <a href="/" class="inline-flex items-center bg-white rounded-[var(--radius-md)] px-[14px] py-[8px] shadow-[0_4px_12px_rgba(255,255,255,0.05)] border border-white/10 hover:opacity-95 transition-opacity">
            <img src="/images/VodaTravelIcon.webp" alt="Voda Tour & Event" class="h-[40px] w-auto object-contain" />
          </a>
        </div>
        <p class="text-white/60 text-[13.5px] leading-relaxed max-w-[280px] m-0">
          Perjalanan berkesan, momen tak terlupakan. Spesialis private tour &amp; corporate event terpercaya sejak 2024.
        </p>
        <!-- Social Icons Row -->
        <div class="flex items-center gap-[10px]">
          <a href={`https://instagram.com/${s.instagram}`} target="_blank" rel="noopener noreferrer" class="w-[36px] h-[36px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/70 hover:bg-orange-500 hover:text-white hover:border-orange-500 hover:-translate-y-[2px] transition-all duration-[0.2s]" aria-label="Instagram">
            <i class="fa-brands fa-instagram text-[16px]"></i>
          </a>
          <a href={`https://wa.me/${s.whatsapp}`} target="_blank" rel="noopener noreferrer" class="w-[36px] h-[36px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/70 hover:bg-orange-500 hover:text-white hover:border-orange-500 hover:-translate-y-[2px] transition-all duration-[0.2s]" aria-label="WhatsApp">
            <i class="fa-brands fa-whatsapp text-[16px]"></i>
          </a>
          <a href={`mailto:${s.email}`} class="w-[36px] h-[36px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/70 hover:bg-orange-500 hover:text-white hover:border-orange-500 hover:-translate-y-[2px] transition-all duration-[0.2s]" aria-label="Email">
            <i class="fa-solid fa-envelope text-[15px]"></i>
          </a>
        </div>
      </div>

      <!-- Col 2: Navigasi -->
      <div>
        <h4 class="font-[family-name:var(--font-body)] font-semibold text-white text-[13px] tracking-[0.15em] uppercase pb-[8px] border-b border-orange-500/30 inline-block mb-[20px]">Navigasi</h4>
        <ul class="space-y-[10px] list-none p-0 m-0">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.url}
                class="text-white/60 text-[13.5px] no-underline transition-all duration-[0.2s] hover:text-orange-400 hover:pl-[4px] inline-block"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Kontak -->
      <div>
        <h4 class="font-[family-name:var(--font-body)] font-semibold text-white text-[13px] tracking-[0.15em] uppercase pb-[8px] border-b border-orange-500/30 inline-block mb-[20px]">Hubungi Kami</h4>
        <ul class="space-y-[14px] list-none p-0 m-0">
          <li>
            <a href={`https://wa.me/${s.whatsapp}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-[12px] text-white/60 text-[13.5px] no-underline transition-colors hover:text-orange-400 group">
              <div class="w-[32px] h-[32px] rounded-full bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-500 shrink-0 text-[15px] group-hover:bg-orange-500 group-hover:text-white transition-colors duration-[0.2s]">
                <i class="fa-brands fa-whatsapp"></i>
              </div>
              <span class="truncate">{s.whatsapp}</span>
            </a>
          </li>
          <li>
            <a href={`tel:${s.phone}`} class="flex items-center gap-[12px] text-white/60 text-[13.5px] no-underline transition-colors hover:text-orange-400 group">
              <div class="w-[32px] h-[32px] rounded-full bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-500 shrink-0 text-[14px] group-hover:bg-orange-500 group-hover:text-white transition-colors duration-[0.2s]">
                <i class="fa-solid fa-phone"></i>
              </div>
              <span class="truncate">{s.phone}</span>
            </a>
          </li>
          <li>
            <a href={`mailto:${s.email}`} class="flex items-center gap-[12px] text-white/60 text-[13.5px] no-underline transition-colors hover:text-orange-400 group">
              <div class="w-[32px] h-[32px] rounded-full bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-500 shrink-0 text-[14px] group-hover:bg-orange-500 group-hover:text-white transition-colors duration-[0.2s]">
                <i class="fa-solid fa-envelope"></i>
              </div>
              <span class="truncate">{s.email}</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 4: Kantor & Alamat -->
      <div>
        <h4 class="font-[family-name:var(--font-body)] font-semibold text-white text-[13px] tracking-[0.15em] uppercase pb-[8px] border-b border-orange-500/30 inline-block mb-[20px]">Kantor Kami</h4>
        <div class="flex items-start gap-[12px] text-white/60 text-[13.5px]">
          <div class="w-[32px] h-[32px] rounded-full bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-500 shrink-0 text-[14px]">
            <i class="fa-solid fa-location-dot"></i>
          </div>
          <p class="m-0 leading-relaxed max-w-[200px]">
            {s.address}
          </p>
        </div>
      </div>

    </div>
  </div>

  <!-- Copyright bar -->
  <div class="border-t border-white/5">
    <div class="wrap py-[20px] flex flex-col sm:flex-row items-center justify-between gap-[10px]">
      <p class="text-white/40 text-[12px] m-0">
        &copy; {new Date().getFullYear()} {s.site_name}. All rights reserved.
      </p>
      <!-- <p class="text-white/30 text-[11px] m-0">
        Designed with <i class="fa-solid fa-heart text-orange-500 text-[10px]"></i> for unforgettable moments
      </p> -->
    </div>
  </div>
</footer>
