---
// Voda Tour & Event — CTABand Component
// Call-to-action band with heading, CTA button, and feature chips

interface Props {
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaUrl?: string;
  features?: { icon: string; label: string }[];
}

const {
  heading = "Siap untuk Pengalaman Tak Terlupakan?",
  description = "Hubungi kami sekarang dan dapatkan penawaran terbaik untuk perjalanan atau event Anda.",
  ctaLabel = "Hubungi Kami",
  ctaUrl,
  features: featureProps,
} = Astro.props;

const defaultFeatures = [
  { icon: "fa-solid fa-map-marked-alt", label: "Destinasi Terkurasi" },
  { icon: "fa-solid fa-tag", label: "Harga Transparan" },
  { icon: "fa-solid fa-users", label: "Tim Profesional" },
  { icon: "fa-solid fa-headset", label: "24/7 Support" },
];

const features = featureProps || defaultFeatures;
const whatsappUrl = ctaUrl || "https://wa.me/6282112345678?text=Halo%20Voda%20Tour%20%26%20Event%2C%20saya%20tertarik%20dengan%20penawaran%20Anda.";
---

<section class="bg-gradient-to-r from-[#122A3D] to-[#356E78]">
  <div class="wrap py-[70px] max-lg:py-[50px]">
    <!-- Top: heading + description + CTA -->
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-[24px] pb-[34px] border-b border-white/10">
      <div class="max-w-[600px]">
        <h2 class="font-[family-name:var(--font-display)] text-white font-bold text-[34px] max-lg:text-[28px] leading-[1.15]">{heading}</h2>
        <p class="text-white/65 text-[15px] leading-relaxed mt-[8px]">{description}</p>
      </div>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-[10px] bg-orange-600 text-white rounded-[999px] px-[28px] py-[14px] font-semibold text-[14.5px] no-underline shadow-[0_14px_28px_-10px_rgba(238,125,15,0.55)] transition-all duration-[0.18s] hover:-translate-y-[2px] hover:shadow-[0_18px_34px_-10px_rgba(238,125,15,0.65)] shrink-0"
      >
        <i class="fa-brands fa-whatsapp text-[18px]"></i>
        {ctaLabel}
      </a>
    </div>

    <!-- Bottom: feature chips -->
    <div class="flex flex-wrap gap-[20px] mt-[30px]">
      {features.map((f) => (
        <div class="flex items-center gap-[10px] bg-white/10 rounded-[999px] px-[14px] py-[8px]">
          <div class="w-[32px] h-[32px] bg-white/15 rounded-[8px] flex items-center justify-center text-orange-400 text-[14px]">
            <i class={f.icon}></i>
          </div>
          <span class="text-white/85 text-[13px] font-medium">{f.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
