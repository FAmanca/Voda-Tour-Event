---
// Voda Tour & Event — SearchCard Component (Deep Search + Tracking)
// Landing page search: text autocomplete + date + kegiatan + pax
// Semua pencarian dicatat ke tabel searches via logSearch()

import type { Destination } from "../types/directus";
import type { ActivityType } from "../types/directus";

interface Props {
  destinations?: Destination[];
  activityTypes?: ActivityType[];
}

const { destinations = [], activityTypes = [] } = Astro.props;
---

<div class="bg-gradient-to-b from-navy-800 to-navy-900 rounded-[var(--radius-lg)] p-[28px] max-lg:p-[22px] shadow-[var(--shadow-card)]">
  <h3 class="font-[family-name:var(--font-display)] text-white font-bold text-[17px]">Cari Paket Terbaik untuk Anda</h3>
  <div class="w-[40px] h-[2px] bg-orange-600 rounded-full mt-[10px] mb-[20px]"></div>

  <form id="search-card-form" method="GET" action="/cari" class="space-y-[14px]">
    <!-- Text Search with Autocomplete -->
    <div class="sm:col-span-2 relative">
      <label class="block text-[11px] font-semibold text-white/60 uppercase tracking-[0.08em] mb-[6px]">Cari Destinasi atau Paket</label>
      <div class="relative">
        <input
          id="search-card-input"
          type="text"
          name="q"
          placeholder="Ketik nama destinasi atau paket..."
          autocomplete="off"
          class="w-full bg-white/10 border border-white/15 rounded-[var(--radius-sm)] px-[14px] py-[11px] pl-[38px] text-white text-[13px] placeholder:text-white/30 outline-none focus:border-orange-600/50 transition-colors"
        />
        <i class="fa-solid fa-search absolute left-[12px] top-1/2 -translate-y-1/2 text-white/30 text-[12px] pointer-events-none"></i>
        <!-- Autocomplete Dropdown -->
        <div id="search-card-dropdown" class="hidden absolute left-0 right-0 top-full mt-[4px] bg-white rounded-[var(--radius-lg)] shadow-[0_12px_40px_rgba(0,0,0,0.15)] border border-navy-100 z-[999] overflow-hidden max-h-[320px] overflow-y-auto"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-[14px]">
      <!-- Travel Date -->
      <div>
        <label class="block text-[11px] font-semibold text-white/60 uppercase tracking-[0.08em] mb-[6px]">Tanggal Berangkat</label>
        <div class="relative">
          <input type="date" name="tanggal" class="w-full bg-white/10 border border-white/15 rounded-[var(--radius-sm)] px-[14px] py-[11px] text-white text-[13px] outline-none focus:border-orange-600/50 transition-colors [color-scheme:dark]" />
          <i class="fa-regular fa-calendar absolute right-[12px] top-1/2 -translate-y-1/2 text-white/30 text-[12px] pointer-events-none"></i>
        </div>
      </div>

      <!-- Kegiatan -->
      <div>
        <label class="block text-[11px] font-semibold text-white/60 uppercase tracking-[0.08em] mb-[6px]">Kegiatan</label>
        <div class="relative">
          <select name="kegiatan" class="w-full bg-white/10 border border-white/15 rounded-[var(--radius-sm)] px-[14px] py-[11px] text-white/70 text-[13px] outline-none focus:border-orange-600/50 transition-colors appearance-none">
            <option value="" class="text-navy-800">Semua Kegiatan</option>
            {activityTypes.map((a) => (
              <option value={a.slug}>{a.name}</option>
            ))}
          </select>
          <i class="fa-solid fa-chevron-down absolute right-[12px] top-1/2 -translate-y-1/2 text-white/30 text-[10px] pointer-events-none"></i>
        </div>
      </div>

      <!-- Pax -->
      <div>
        <label class="block text-[11px] font-semibold text-white/60 uppercase tracking-[0.08em] mb-[6px]">Jumlah Peserta</label>
        <div class="relative">
          <input type="number" name="pax" min="1" placeholder="Mis: 10" class="w-full bg-white/10 border border-white/15 rounded-[var(--radius-sm)] px-[14px] py-[11px] text-white text-[13px] placeholder:text-white/30 outline-none focus:border-orange-600/50 transition-colors" />
          <i class="fa-solid fa-user absolute right-[12px] top-1/2 -translate-y-1/2 text-white/30 text-[12px] pointer-events-none"></i>
        </div>
      </div>
    </div>

    <!-- Submit -->
    <button type="submit" class="w-full py-[12px] bg-orange-600 hover:bg-orange-500 text-white font-semibold text-[14px] rounded-[var(--radius-sm)] transition-colors flex items-center justify-center gap-[8px]">
      <i class="fa-solid fa-search"></i>
      Cari Paket
    </button>
  </form>
</div>

<script>
import { initAutocomplete, logSearch } from "../lib/search";
window.__DIRECTUS_URL__ = window.__DIRECTUS_URL__ || "{import.meta.env.DIRECTUS_URL || 'http://localhost:8055'}";

document.addEventListener("DOMContentLoaded", function () {
  // Init autocomplete
  initAutocomplete("search-card-input", "search-card-dropdown");

  // Validation helper
  function showFieldError(inputEl, msg) {
    var key = (inputEl.id || inputEl.name || 'field') + '-error';
    var err = document.getElementById(key);
    if (!err) {
      err = document.createElement('p');
      err.id = key;
      err.className = 'text-[11px] text-red-400 mt-[4px]';
      inputEl.parentNode.appendChild(err);
    }
    err.textContent = msg;
    inputEl.style.borderColor = 'rgba(248,113,113,0.5)';
  }

  function clearFieldError(inputEl) {
    var key = (inputEl.id || inputEl.name || 'field') + '-error';
    var err = document.getElementById(key);
    if (err) err.remove();
    inputEl.style.borderColor = '';
  }

  // Log search on form submit
  var form = document.getElementById("search-card-form");
  if (form) {
    form.addEventListener("submit", function (e) {
      // === VALIDATION ===
      var valid = true;
      var qInput = document.querySelector("#search-card-form input[name='q']");
      var kegSelect = document.querySelector("#search-card-form select[name='kegiatan']");

      if (qInput && qInput.dataset.searchValid !== 'true') {
        showFieldError(qInput, 'Harap pilih destinasi atau paket dari daftar yang muncul');
        valid = false;
      } else if (qInput) {
        clearFieldError(qInput);
      }

      if (kegSelect && !kegSelect.value) {
        showFieldError(kegSelect, 'Harap pilih jenis kegiatan');
        valid = false;
      } else if (kegSelect) {
        clearFieldError(kegSelect);
      }

      if (!valid) { e.preventDefault(); return; }

      // === PROCEED ===
      e.preventDefault();
      var fd = new FormData(form);
      var q = fd.get("q") || "";
      var keg = fd.get("kegiatan") || "";
      var tgl = fd.get("tanggal") || "";
      var pax = fd.get("pax") || "";
      logSearch({
        query: q,
        activity_type_name: keg,
        travel_date: tgl,
        pax_count: pax ? parseInt(pax) : null,
      }).then(function () {
        var sp = new URLSearchParams();
        if (q) sp.set("q", q);
        if (keg) sp.set("kegiatan", keg);
        if (pax) sp.set("pax", pax);
        window.location.href = "/cari?" + sp.toString();
      });
    });
  }
});
</script>