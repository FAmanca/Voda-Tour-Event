---
// Voda Tour & Event — SearchResult Component (Redesigned)
// Client-side rendered search results with loading/empty/error states

import PackageCard from "./PackageCard.astro";
import type { PackageWithDestination } from "../types/directus";

interface Props {
  packages: PackageWithDestination[];
  loading?: boolean;
  error?: string | null;
  totalCount?: number;
}
---

<div id="search-results">
  {Astro.props.error && (
    <div class="rounded-[var(--radius-md)] bg-red-50 border border-red-200 p-[18px] text-red-700 text-[14px] flex items-start gap-[10px]">
      <i class="fa-solid fa-circle-exclamation mt-[2px] shrink-0"></i>
      <span>{Astro.props.error}</span>
    </div>
  )}

  {Astro.props.loading && (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[28px]">
      {[1, 2, 3, 4, 5, 6].map((i) => (
        <div class="rounded-[var(--radius-md)] bg-navy-50 animate-pulse overflow-hidden" key={i}>
          <div class="h-[150px] bg-navy-100"></div>
          <div class="p-[18px] space-y-[10px]">
            <div class="h-[16px] bg-navy-100 rounded w-[70%]"></div>
            <div class="h-[12px] bg-navy-50 rounded w-[50%]"></div>
            <div class="flex justify-between pt-[10px] border-t border-navy-100">
              <div class="h-[12px] bg-navy-50 rounded w-[60px]"></div>
              <div class="h-[12px] bg-navy-50 rounded w-[80px]"></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}

  {!Astro.props.loading && !Astro.props.error && (
    <>
      {Astro.props.totalCount !== undefined && (
        <p class="text-navy-500 text-[13px] mb-[20px]">
          <strong class="text-navy-800">{Astro.props.totalCount}</strong> paket ditemukan
        </p>
      )}

      {Astro.props.packages.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[28px]">
          {Astro.props.packages.map((pkg) => <PackageCard package={pkg} showDestination />)}
        </div>
      ) : (
        <div class="text-center py-[60px]">
          <i class="fa-regular fa-face-frown text-[48px] text-navy-300 block mb-[16px]"></i>
          <h3 class="font-[family-name:var(--font-display)] text-navy-600 text-[20px] font-semibold">Paket Tidak Ditemukan</h3>
          <p class="text-navy-400 text-[14px] mt-[8px] max-w-[400px] mx-auto">Coba ubah kata kunci atau filter pencarian kamu.</p>
        </div>
      )}
    </>
  )}
</div>