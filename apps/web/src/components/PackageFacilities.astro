---
interface Props {
  facilities: string[];
}
const { facilities } = Astro.props;
---
<section class="py-16 max-lg:py-12"><div class="wrap">
  <div class="text-center mb-9">
    <span class="text-xs font-semibold text-orange-600 uppercase tracking-widest">Fasilitas</span>
    <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-3xl max-lg:text-2xl font-bold mt-2">Apa yang Termasuk?</h2>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3.5 max-w-4xl mx-auto">
    {facilities.map((f) => (
      <div class="flex items-start gap-3 bg-white border border-[--color-line] rounded-[var(--radius-md)] p-4 hover:border-orange-200 hover:shadow-sm transition-all">
        <div class="w-7 h-7 rounded-full bg-green-100 flex items-center justify-center text-green-600 text-xs shrink-0 mt-[1px]">
          <i class="fa-solid fa-check"></i>
        </div>
        <span class="text-navy-700 text-sm leading-relaxed">{f}</span>
      </div>
    ))}
  </div>
</div></section>
