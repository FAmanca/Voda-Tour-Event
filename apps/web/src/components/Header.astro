---
// Voda Tour & Event — Header Component
// Sticky white header: logo + nav + actions (phone + WA)

interface Props {
  active?: 'beranda' | 'paket' | 'gathering' | 'destinasi' | 'tentang' | 'kontak';
  settings?: {
    whatsapp?: string;
    phone?: string;
  };
}

const { active, settings = {} } = Astro.props;

const navItems = [
  { slug: 'beranda', label: 'Beranda', url: '/' },
  { slug: 'paket', label: 'Paket Wisata', url: '/paket' },
  { slug: 'gathering', label: 'Gathering & Event', url: '/gathering' },
  { slug: 'destinasi', label: 'Destinasi', url: '/destinasi' },
  { slug: 'tentang', label: 'Tentang Kami', url: '/tentang' },
  { slug: 'kontak', label: 'Kontak', url: '/kontak' },
];

const phone = settings.phone || '6282112345678';
const phoneDisplay = settings.phone
  ? settings.phone.replace(/^62/, '0').replace(/(\d{4})(\d{4})(\d{4})/, '$1-$2-$3')
  : '0821-1234-5678';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-[--color-line]">
  <div class="wrap">
    <div class="flex items-center justify-between h-[88px] max-lg:h-[76px] gap-6">

      <!-- Logo -->
      <a href="/" class="flex items-center shrink-0 no-underline">
        <img src="/images/VodaTravelIcon.webp" alt="Voda Tour & Event" class="h-[100px] w-auto max-lg:h-[68px]" />
      </a>

      <!-- Nav -->
      <nav class="hidden lg:flex items-center gap-[14px]">
        {navItems.map((item) => (
          <a
            href={item.url}
            class:list={[
              'relative px-[6px] py-[8px] font-[family-name:var(--font-body)] text-[14px] font-semibold transition-colors no-underline',
              active === item.slug
                ? 'text-orange-600 after:absolute after:bottom-[-2px] after:left-1/2 after:-translate-x-1/2 after:w-[calc(100%+8px)] after:h-[2.5px] after:bg-orange-600 after:rounded-full'
                : 'text-navy-800 hover:text-orange-600',
            ]}
          >
            {item.label}
            {item.hasDropdown && <i class="fa-solid fa-chevron-down text-[10px] ml-[4px] opacity-50"></i>}
          </a>
        ))}
      </nav>

      <!-- Actions -->
      <div class="flex items-center gap-[14px] shrink-0">
        <a
          href={`tel:${phone}`}
          class="hidden sm:inline-flex items-center gap-[8px] px-[16px] py-[9px] border border-[--color-line] rounded-[999px] text-[13px] font-semibold text-navy-800 no-underline transition-colors hover:border-navy-800"
        >
          <i class="fa-solid fa-phone text-[12px]"></i>
          <span class="hidden md:inline">{phoneDisplay}</span>
        </a>

        <a
          href={`https://wa.me/${phone}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-[8px] px-[18px] py-[9px] bg-orange-600 text-white rounded-[999px] text-[13px] font-semibold no-underline shadow-[0_10px_20px_-8px_rgba(238,125,15,0.5)] transition-all duration-[0.18s] hover:-translate-y-[1px] hover:shadow-[0_14px_24px_-8px_rgba(238,125,15,0.6)]"
        >
          <i class="fa-brands fa-whatsapp text-[14px]"></i>
          <span class="hidden md:inline">Konsultasi Gratis</span>
        </a>

        <!-- Burger -->
        <button id="menu-toggle" class="lg:hidden flex items-center justify-center w-[40px] h-[40px] text-navy-800 text-[20px] bg-transparent border-none cursor-pointer" aria-label="Buka menu" aria-expanded="false">
          <i id="menu-icon" class="fa-solid fa-bars"></i>
        </button>
      </div>

    </div>
  </div>
  <!-- Mobile Menu Overlay -->
  <div id="menu-overlay" class="fixed inset-0 z-40 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden" aria-hidden="true"></div>

  <!-- Mobile Menu Panel -->
  <div id="menu-panel" class="fixed top-0 right-0 z-50 h-full w-[300px] max-w-[85vw] bg-white shadow-2xl translate-x-full transition-transform duration-300 ease-out lg:hidden flex flex-col">
    <!-- Panel header -->
    <div class="flex items-center justify-between px-[24px] h-[76px] border-b border-[--color-line] shrink-0">
      <span class="font-[family-name:var(--font-display)] text-navy-800 text-[18px] font-bold">Menu</span>
      <button id="menu-close" class="flex items-center justify-center w-[36px] h-[36px] text-navy-500 text-[18px] bg-navy-50 rounded-full border-none cursor-pointer transition-colors hover:bg-navy-100" aria-label="Tutup menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <!-- Panel nav links -->
    <nav class="flex-1 overflow-y-auto py-[16px] px-[24px]">
      <ul class="list-none p-0 m-0 flex flex-col gap-[4px]">
        {navItems.map((item) => (
          <li>
            <a
              href={item.url}
              class:list={[
                'flex items-center justify-between px-[16px] py-[14px] rounded-[12px] text-[15px] font-semibold no-underline transition-colors duration-[0.15s]',
                active === item.slug
                  ? 'text-orange-600 bg-orange-50'
                  : 'text-navy-800 hover:bg-navy-50',
              ]}
              data-nav-link
            >
              <span>{item.label}</span>
              <i class="fa-solid fa-chevron-right text-[10px] opacity-30"></i>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Panel footer: phone -->
    <div class="px-[24px] py-[20px] border-t border-[--color-line] shrink-0">
      <a
        href={`tel:${phone}`}
        class="flex items-center gap-[12px] px-[16px] py-[12px] rounded-[12px] bg-navy-50 text-navy-800 no-underline font-medium text-[14px] transition-colors hover:bg-navy-100"
      >
        <i class="fa-solid fa-phone text-[14px] text-orange-600"></i>
        {phoneDisplay}
      </a>
    </div>
  </div>

  <!-- Mobile Menu Script -->
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var toggle = document.getElementById('menu-toggle');
      var closeBtn = document.getElementById('menu-close');
      var panel = document.getElementById('menu-panel');
      var overlay = document.getElementById('menu-overlay');
      var links = panel.querySelectorAll('[data-nav-link]');
      var icon = document.getElementById('menu-icon');

      function openMenu() {
        panel.classList.remove('translate-x-full');
        overlay.classList.remove('opacity-0', 'pointer-events-none');
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', 'Tutup menu');
        icon.className = 'fa-solid fa-xmark';
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        panel.classList.add('translate-x-full');
        overlay.classList.add('opacity-0', 'pointer-events-none');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Buka menu');
        icon.className = 'fa-solid fa-bars';
        document.body.style.overflow = '';
      }

      toggle.addEventListener('click', function () {
        if (panel.classList.contains('translate-x-full')) openMenu();
        else closeMenu();
      });

      closeBtn.addEventListener('click', closeMenu);
      overlay.addEventListener('click', closeMenu);

      // Close on link click
      links.forEach(function (link) {
        link.addEventListener('click', closeMenu);
      });

      // Close on Escape
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !panel.classList.contains('translate-x-full')) closeMenu();
      });
    });
  </script>
</header>
