---
// Voda Tour & Event — StatsBar Component
// Navy solid bar: 4 stats on the left, testimonial card on the right
interface StatsItem {
  icon: string;
  value: string;   // e.g. "200+"
  label: string;   // e.g. "Paket Wisata"
  sublabel?: string; // e.g. "Menarik"
}
interface Testimonial {
  quote: string;
  name: string;
  role: string;
  avatar?: string; // optional — falls back to initials badge if omitted/broken
  rating?: number; // default 5
}
interface Props {
  stats?: StatsItem[];
  testimonial?: Testimonial;
}

const defaultStats: StatsItem[] = [
  { icon: "fa-solid fa-suitcase-rolling", value: "200+",  label: "Paket Wisata",       sublabel: "Menarik" },
  { icon: "fa-solid fa-users",            value: "500+",  label: "Event & Gathering",  sublabel: "Sukses" },
  { icon: "fa-solid fa-face-smile",       value: "1000+", label: "Pelanggan",          sublabel: "Puas" },
  { icon: "fa-solid fa-location-dot",     value: "50+",   label: "Destinasi",          sublabel: "Populer" },
];

const defaultTestimonial: Testimonial = {
  quote: "Pelayanan memuaskan, itinerary seru, dan tim sangat profesional.",
  name: "Andri Pratama",
  role: "PT. Maju Bersama",
  rating: 5,
};

const stats = Astro.props.stats || defaultStats;
const testimonial = Astro.props.testimonial || defaultTestimonial;

const initials = testimonial.name
  .split(" ")
  .map((w) => w[0])
  .slice(0, 2)
  .join("")
  .toUpperCase();
---

<div class="relative z-20 -mt-[64px] max-lg:-mt-0 max-lg:pt-[40px]">
  <div class="wrap">
    <div class="bg-navy-900 rounded-[var(--radius-lg)] shadow-[var(--shadow-card)] px-[36px] py-[28px] max-lg:px-[24px] max-lg:py-[24px] overflow-hidden">
      <div class="flex items-center justify-between gap-[32px] max-lg:flex-col max-lg:items-stretch">

        <div class="flex flex-1 min-w-0 items-center justify-between gap-x-[16px] divide-x divide-white/10 max-md:grid max-md:grid-cols-2 max-md:gap-[16px] max-md:divide-x-0">
          {stats.map((s) => (
            <div class="flex items-center gap-[12px] first:pl-0 pl-[16px] max-md:pl-0">
              {/* Ukuran Lingkaran Ikon */}
              <div class="w-[40px] h-[40px] rounded-full border border-white/15 bg-white/5 flex items-center justify-center text-orange-500 text-[16px] shrink-0">
                <i class={s.icon}></i>
              </div>
              <div class="min-w-0">
                {/* Ukuran Angka Stat */}
                <div class="font-[family-name:var(--font-display)] text-white font-bold text-[18px] leading-none">
                  {s.value}
                </div>
                {/* Ukuran Label */}
                <div class="text-white/70 text-[12px] leading-tight mt-[4px] whitespace-nowrap">
                  {s.label}{s.sublabel ? ` ${s.sublabel}` : ""}
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="w-px h-[48px] bg-white/10 shrink-0 max-lg:hidden"></div>

        <div class="flex items-start gap-[16px] max-w-[360px] shrink-0 max-lg:max-w-full max-lg:pt-[20px] max-lg:border-t max-lg:border-white/10">
          <i class="fa-solid fa-quote-left text-orange-500 text-[24px] shrink-0 mt-[2px] opacity-80"></i>
          <div class="min-w-0 flex-1">
            <p class="text-white text-[13px] leading-relaxed italic opacity-90">
              "{testimonial.quote}"
            </p>
            
            <div class="flex items-center gap-[12px] mt-[12px]">
              {testimonial.avatar ? (
                <img
                  src={testimonial.avatar}
                  alt={testimonial.name}
                  class="w-[40px] h-[40px] rounded-full object-cover shrink-0 border border-white/10"
                />
              ) : (
                <div class="w-[40px] h-[40px] rounded-full bg-orange-500/20 border border-orange-500/40 flex items-center justify-center text-orange-500 text-[13px] font-bold shrink-0">
                  {initials}
                </div>
              )}
              
              <div class="min-w-0">
                <div class="flex items-center gap-[2px] text-orange-500 text-[10px]">
                  {Array.from({ length: testimonial.rating ?? 5 }).map(() => (
                    <i class="fa-solid fa-star"></i>
                  ))}
                </div>
                <div class="text-white text-[13px] font-semibold leading-tight mt-[3px] truncate">
                  {testimonial.name}
                </div>
                <div class="text-white/60 text-[11px] leading-tight mt-[1px] truncate">
                  {testimonial.role}
                </div>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>
</div>