---
// Voda Tour & Event — StatsBar Component
// Full-width navy section: 4 stats + testimonial card

interface StatsItem {
  icon: string;
  number: string;
  label: string;
  sublabel: string;
}

interface Props {
  stats?: StatsItem[];
  testimonial?: {
    quote: string;
    name: string;
    company: string;
  };
}

const defaultStats: StatsItem[] = [
  { icon: "fa-solid fa-map-marked-alt", number: "500+", label: "Paket Wisata", sublabel: "Tersedia" },
  { icon: "fa-solid fa-users", number: "2.500+", label: "Pelanggan", sublabel: "Puas & Bahagia" },
  { icon: "fa-solid fa-calendar-check", number: "300+", label: "Acara", sublabel: "Sukses Terselenggara" },
  { icon: "fa-solid fa-star", number: "4.9", label: "Rating", sublabel: "Ulasan Pelanggan" },
];

const defaultTestimonial = {
  quote: "Pelayanan luar biasa! Acara gathering perusahaan kami berjalan lancar berkat tim Voda. Sangat recommended!",
  name: "Andi Pratama",
  company: "PT. Maju Bersama",
};

const stats = Astro.props.stats || defaultStats;
const testimonial = Astro.props.testimonial || defaultTestimonial;
---

<section class="bg-navy-900">
  <div class="wrap py-[70px] max-lg:py-[50px]">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-[40px] max-lg:gap-[34px]">

      <!-- Stats column (2/3) -->
      <div class="lg:col-span-2">
        <div class="grid grid-cols-2 gap-[28px] max-lg:gap-[20px]">
          {stats.map((s, i) => (
            <div class="flex items-start gap-[14px]">
              <div class="w-[46px] h-[46px] rounded-full border-[1.5px] border-white/15 flex items-center justify-center text-orange-500 text-[20px] shrink-0">
                <i class={s.icon}></i>
              </div>
              <div>
                <div class="font-[family-name:var(--font-display)] text-white font-bold text-[28px] leading-none">{s.number}</div>
                <div class="text-white/80 text-[14px] font-semibold leading-tight mt-[2px]">{s.label}</div>
                <div class="text-white/40 text-[12px] leading-tight mt-[2px]">{s.sublabel}</div>
              </div>
              <!-- Hairline vertical rule (not on last item per row) -->
              {i % 2 === 0 && <div class="hidden lg:block w-[1px] h-[50px] bg-white/10 ml-auto"></div>}
            </div>
          ))}
        </div>
      </div>

      <!-- Testimonial column (1/3) -->
      <div class="border-l border-white/10 pl-[34px] max-lg:border-l-0 max-lg:pl-0 max-lg:pt-[20px] max-lg:border-t max-lg:pt-[24px]">
        <i class="fa-solid fa-quote-left text-orange-500 text-[24px] mb-[14px] block"></i>
        <p class="text-white/80 text-[14px] leading-relaxed italic">&ldquo;{testimonial.quote}&rdquo;</p>
        <div class="flex items-center gap-[6px] mt-[12px]">
          {[1, 2, 3, 4, 5].map(() => (
            <i class="fa-solid fa-star text-orange-500 text-[12px]"></i>
          ))}
        </div>
        <div class="flex items-center gap-[14px] mt-[16px]">
          <div class="w-[42px] h-[42px] rounded-full border-[2px] border-orange-600 bg-navy-700 flex items-center justify-center text-white text-[15px] font-semibold">
            {testimonial.name.charAt(0)}
          </div>
          <div>
            <div class="text-white font-semibold text-[14px] leading-tight">{testimonial.name}</div>
            <div class="text-white/40 text-[12px] leading-tight">{testimonial.company}</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
