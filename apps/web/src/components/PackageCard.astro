---
// Voda Tour & Event — PackageCard Component
// Individual package card with photo area, icon badge, price

import type { PackageWithDestination } from "../types/directus";
import { getAssetUrl } from "../lib/directus";
import { getStartingPrice } from "../lib/utils";

interface Props {
  /** Alternate: pass full package object */
  package?: PackageWithDestination;
  /** Show destination name */
  showDestination?: boolean;
  title?: string;
  description?: string;
  slug?: string;
  /** Price tier pertama sebagai harga mulai */
  priceFrom?: number;
  image?: string;
  icon?: string;
  category?: string;
  lcp?: boolean;
}

const {
  title: _title,
  description: _desc,
  slug: _slug,
  priceFrom: _priceFrom,
  image: _img,
  icon = "fa-solid fa-map-marked-alt",
  category = 'wisata',
  showDestination,
  lcp = false,
  package: pkg,
} = Astro.props;

// Support both individual props AND full package object
const title = _title || pkg?.name || '';
const description = _desc || pkg?.description || '';
const slug = _slug || pkg?.slug || '';
const priceFrom = _priceFrom ?? (pkg ? getStartingPrice(pkg.price_tiers || []) : undefined);
const image = _img || (pkg?.image ? getAssetUrl(pkg.image) + '?width=400&height=250&fit=cover&format=webp' : undefined);
const destName = pkg?.destination_id
  ? (typeof pkg.destination_id === 'object' ? pkg.destination_id?.name : '')
  : '';

const displayPrice = priceFrom
  ? new Intl.NumberFormat('id-ID').format(priceFrom)
  : null;
---

<a
  href={`/paket/${slug}`}
  class="group relative block w-full min-h-[340px] flex flex-col justify-end rounded-[var(--radius-md)] shadow-[var(--shadow-soft)] overflow-hidden no-underline transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[var(--shadow-card)]"
>
  <!-- Background Image & Overlay -->
  <div class="absolute inset-0 bg-navy-950 z-0">
    {image ? (
      <img
        src={image}
        alt={title}
        width="400"
        height="250"
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105 group-hover:rotate-1"
        loading={lcp ? "eager" : "lazy"}
        fetchpriority={lcp ? "high" : "auto"}
      />
    ) : (
      <div class="w-full h-full flex flex-col items-center justify-center text-white/20">
        <i class="fa-regular fa-image text-5xl"></i>
        <span class="text-xs mt-2 font-medium">No Image</span>
      </div>
    )}
    <!-- Dark Navy Gradient overlay from bottom to top -->
    <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/85 to-navy-950/20"></div>
  </div>

  <!-- Icon badge pinned top-left -->
  <div class="absolute top-4 left-4 z-10 w-10 h-10 bg-white rounded-full flex items-center justify-center text-navy-800 text-base shadow-[0_4px_12px_rgba(0,0,0,0.15)]">
    <i class={icon}></i>
  </div>

  <!-- Body Content -->
  <div class="relative z-10 p-5">
    <h3 class="font-[family-name:var(--font-display)] text-white font-semibold text-base leading-tight line-clamp-2">{title}</h3>
    <p class="text-white/70 text-sm leading-relaxed mt-1.5 line-clamp-2">{description}</p>
    {showDestination && destName && <p class="text-xs text-white/50 mt-2"><i class="fa-solid fa-location-dot text-orange-400 text-[10px] mr-1"></i>{destName}</p>}

    <!-- Dashed divider -->
    <div class="border-t border-dashed border-white/15 my-3.5"></div>

    <!-- Price row -->
    <div class="flex items-center justify-between">
      <div>
        {displayPrice ? (
          <>
            <span class="text-xs text-white/50 font-medium block leading-none">Mulai dari</span>
            <span class="font-[family-name:var(--font-display)] text-orange-400 font-bold text-base leading-tight">Rp {displayPrice}</span>
          </>
        ) : (
          <span class="text-xs text-white/60 italic">Hubungi kami</span>
        )}
      </div>
      <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-navy-950 text-sm transition-all duration-200 group-hover:bg-orange-500 group-hover:text-white group-hover:scale-110">
        <i class="fa-solid fa-arrow-right"></i>
      </div>
    </div>
  </div>
</a>
