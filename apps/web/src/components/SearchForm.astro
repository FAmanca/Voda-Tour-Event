---
// Voda Tour & Event — SearchForm Component (Synced with Landing SearchCard)
// Fields: q (autocomplete) + tanggal + kegiatan + pax
// Semua pencarian dicatat ke tabel searches via logSearch()

import type { Destination } from "../types/directus";
import type { ActivityType } from "../types/directus";

interface Props {
  destinations: Destination[];
  activityTypes: ActivityType[];
  initialValues?: {
    q?: string;
    activityType?: string;
    paxCount?: number;
    travelDate?: string;
  };
}

const { destinations, activityTypes, initialValues } = Astro.props;
const iv = initialValues || {};
---

<div class="relative w-full max-w-5xl mx-auto">
  <form id="search-form" method="GET" action="/cari" class="relative z-10 flex flex-col md:flex-row items-center bg-white/10 backdrop-blur-xl border border-white/20 rounded-[32px] md:rounded-[60px] p-2 md:p-3 shadow-2xl transition-all duration-300 hover:shadow-orange-500/10 hover:border-white/30">
    
    <!-- Text Search -->
    <div class="relative w-full md:w-auto md:flex-1 group">
      <div class="px-5 py-2 md:py-1">
        <label for="search-input" class="block text-[10px] font-bold text-orange-400 uppercase tracking-widest mb-1">Tujuan</label>
        <input
          id="search-input"
          type="text"
          name="q"
          placeholder="Cari destinasi / paket"
          value={iv.q || ""}
          autocomplete="off"
          class="w-full bg-transparent text-[15px] font-medium text-white placeholder:text-white/40 outline-none truncate"
        />
      </div>
      <!-- Autocomplete Dropdown -->
      <div id="search-dropdown" role="listbox" class="hidden absolute left-0 right-0 top-[120%] bg-white rounded-2xl shadow-2xl border border-navy-100 z-[999] overflow-hidden max-h-[320px] overflow-y-auto"></div>
    </div>

    <div class="hidden md:block w-[1px] h-10 bg-white/10"></div>

    <!-- Tanggal -->
    <div class="relative w-full md:w-auto md:flex-[0.8] px-5 py-3 md:py-1 border-t border-white/5 md:border-t-0">
      <label for="search-form-date" class="block text-[10px] font-bold text-orange-400 uppercase tracking-widest mb-1">Tanggal</label>
      <input type="date" name="tanggal" id="search-form-date" value={iv.travelDate || ""}
        class="w-full bg-transparent text-[15px] font-medium text-white outline-none cursor-pointer [color-scheme:dark]" />
    </div>

    <div class="hidden md:block w-[1px] h-10 bg-white/10"></div>

    <!-- Kegiatan -->
    <div class="relative w-full md:w-auto md:flex-[0.8] px-5 py-3 md:py-1 border-t border-white/5 md:border-t-0">
      <label for="search-form-kegiatan" class="block text-[10px] font-bold text-orange-400 uppercase tracking-widest mb-1">Kegiatan</label>
      <select name="kegiatan" id="search-form-kegiatan" class="w-full bg-transparent text-[15px] font-medium text-white outline-none cursor-pointer appearance-none">
        <option value="" class="text-navy-800">Semua</option>
        {activityTypes.map((a) => (
          <option value={a.slug} selected={iv.activityType === a.slug} class="text-navy-800">{a.name}</option>
        ))}
      </select>
      <i class="fa-solid fa-chevron-down absolute right-5 top-1/2 -translate-y-1/2 text-white/40 text-[10px] pointer-events-none md:hidden"></i>
    </div>

    <div class="hidden md:block w-[1px] h-10 bg-white/10"></div>

    <!-- Pax -->
    <div class="relative w-full md:w-auto md:flex-[0.6] px-5 py-3 md:py-1 border-t border-white/5 md:border-t-0">
      <label for="search-form-pax" class="block text-[10px] font-bold text-orange-400 uppercase tracking-widest mb-1">Peserta</label>
      <input type="number" name="pax" id="search-form-pax" min="1" placeholder="Berapa orang?" value={iv.paxCount || ""}
        class="w-full bg-transparent text-[15px] font-medium text-white placeholder:text-white/40 outline-none" />
    </div>

    <!-- Submit Button -->
    <div class="w-full md:w-auto mt-2 md:mt-0 p-2 md:p-0">
      <button type="submit" class="w-full md:w-[56px] h-[56px] bg-gradient-to-br from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white rounded-[24px] md:rounded-full flex items-center justify-center gap-2 transition-all duration-300 hover:scale-105 active:scale-95 shadow-[0_8px_20px_rgba(238,125,15,0.4)]">
        <i class="fa-solid fa-search text-[18px]"></i>
        <span class="md:hidden font-semibold">Cari Paket</span>
      </button>
    </div>
  </form>
</div>

<style>
  /* Sembunyikan default calender icon di webkit jika mau UI bersih, tapi biarkan saja agar clickable */
  input[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(1);
    opacity: 0.5;
    cursor: pointer;
  }
</style>

<script define:vars={{ envDirectusUrl: import.meta.env.PUBLIC_DIRECTUS_URL || import.meta.env.DIRECTUS_URL || 'http://localhost:8055' }}>
  window.__DIRECTUS_URL__ = envDirectusUrl;
</script>
<script>
import { initAutocomplete, logSearch } from "../lib/search";
document.addEventListener("DOMContentLoaded", function () {
  initAutocomplete("search-input", "search-dropdown");

  var searchParams = new URLSearchParams(window.location.search);
  var qInput = document.querySelector("input[name='q']");
  if (searchParams.get("q")) { 
    qInput.value = searchParams.get("q"); 
    qInput.dataset.searchValid = 'true'; 
    qInput.dataset.searchLabel = searchParams.get("q"); 
  }
  if (searchParams.get("tanggal")) document.querySelector("input[name='tanggal']").value = searchParams.get("tanggal");
  if (searchParams.get("kegiatan")) document.querySelector("select[name='kegiatan']").value = searchParams.get("kegiatan");
  if (searchParams.get("pax")) document.querySelector("input[name='pax']").value = searchParams.get("pax");

  var form = document.getElementById("search-form");
  if (form) {
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var fd = new FormData(form);
      var q = fd.get("q") || "";
      var kegiatanVal = fd.get("kegiatan") || "";
      var travelDate = fd.get("tanggal") || "";
      var paxVal = fd.get("pax") || "";
      
      logSearch({
        query: q,
        activity_type_name: kegiatanVal,
        travel_date: travelDate,
        pax_count: paxVal ? parseInt(paxVal) : null,
      }).then(function () {
        var searchParamsObj = new URLSearchParams();
        if (q) searchParamsObj.set("q", q);
        if (kegiatanVal) searchParamsObj.set("kegiatan", kegiatanVal);
        if (travelDate) searchParamsObj.set("tanggal", travelDate);
        if (paxVal) searchParamsObj.set("pax", paxVal);
        window.location.href = "/cari?" + searchParamsObj.toString();
      });
    });
  }
});
</script>