---
import Layout from "../../layouts/Layout.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import { getArticles, getAssetUrl } from "../../lib/directus";
import type { Article } from "../../types/directus";

let articles: Article[] = [];
let fetchError = false;

try {
  articles = await getArticles(12);
} catch {
  fetchError = true;
}

// Split into featured (first) + rest
const featured: Article | null = articles.length > 0 ? articles[0] : null;
const gridArticles: Article[] = articles.length > 1 ? articles.slice(1) : [];

/**
 * Strip HTML tags from article content and return a plain-text excerpt.
 * Returns empty string when content isn't a string.
 */
function getExcerpt(content: Article["content"], maxLen = 120): string {
  if (typeof content !== "string") return "";
  const stripped = content.replace(/<[^>]*>/g, "").replace(/\s+/g, " ").trim();
  if (stripped.length <= maxLen) return stripped;
  return stripped.slice(0, maxLen).trimEnd() + "…";
}

function formatDate(dateStr: string | null): string {
  if (!dateStr) return "";
  return new Date(dateStr).toLocaleDateString("id-ID", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---
<Layout
  title="Artikel & Blog | Voda Tour & Event"
  description="Kumpulan artikel perjalanan, tips liburan, dan berita terbaru dari Voda Tour & Event."
  active="beranda"
>
  <main>
    <!-- ================================================================== -->
    <!-- HERO -->
    <!-- ================================================================== -->
    <section class="relative bg-navy-900 py-[100px] max-lg:py-[64px] overflow-hidden">
      <!-- Decorative radial glow -->
      <div class="absolute top-[-120px] right-[-80px] w-[500px] h-[500px] rounded-full bg-orange-600/5 blur-[120px] pointer-events-none"></div>
      <div class="absolute bottom-[-60px] left-[-60px] w-[320px] h-[320px] rounded-full bg-navy-700/30 blur-[100px] pointer-events-none"></div>

      <!-- Subtle grid pattern -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image:url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 0h40v40H0z&quot; fill=&quot;none&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot;/%3E%3C/svg%3E');"></div>

      <div class="wrap relative z-10 text-center">
        <div class="flex justify-center">
          <Eyebrow text="Artikel & Blog" />
        </div>
        <h1 class="font-[family-name:var(--font-display)] text-white text-[44px] max-lg:text-[32px] font-bold mt-[16px] leading-[1.15]">
          Tips & Berita Perjalanan
        </h1>
        <p class="text-white/60 text-[17px] max-lg:text-[15px] mt-[14px] max-w-[540px] mx-auto leading-relaxed">
          Inspirasi destinasi, panduan wisata, dan update terbaru untuk merencanakan perjalanan impian Anda.
        </p>

        <!-- Decorative separator -->
        <div class="flex items-center justify-center gap-[8px] mt-[28px]">
          <span class="block w-[24px] h-[1px] bg-white/20"></span>
          <i class="fa-solid fa-pen-nib text-orange-500/60 text-[11px]"></i>
          <span class="block w-[24px] h-[1px] bg-white/20"></span>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- CONTENT -->
    <!-- ================================================================== -->
    <section class="py-[80px] max-lg:py-[50px] bg-gray-50/60">
      <div class="wrap">

        {/* ------- Error state ------- */}
        {fetchError && (
          <div class="rounded-[var(--radius-md)] bg-red-50 border border-red-200 p-[24px] text-red-700 text-[14px] text-center">
            <i class="fa-solid fa-circle-exclamation mr-[8px]"></i>Gagal memuat artikel. Silakan coba lagi nanti.
          </div>
        )}

        {/* ------- Empty state ------- */}
        {!fetchError && articles.length === 0 && (
          <div class="text-center py-[80px]">
            <div class="w-[80px] h-[80px] rounded-full bg-navy-100 flex items-center justify-center mx-auto mb-[20px]">
              <i class="fa-regular fa-newspaper text-[32px] text-navy-300"></i>
            </div>
            <p class="text-navy-500 text-[17px] font-medium">Belum ada artikel tersedia.</p>
            <p class="text-navy-400 text-[14px] mt-[6px]">Nantikan konten menarik dari kami.</p>
          </div>
        )}

        {/* ------- Featured article ------- */}
        {!fetchError && featured && (() => {
          const imgUrl = featured.featured_image
            ? getAssetUrl(featured.featured_image, { width: 1200, height: 600, format: "webp", quality: 85 })
            : null;
          const date = formatDate(featured.publish_date);
          const excerpt = getExcerpt(featured.content);
          return (
            <a
              href={"/artikel/" + featured.slug}
              class="group relative block bg-white rounded-[var(--radius-lg)] shadow-[var(--shadow-soft)] overflow-hidden no-underline mb-[48px] hover:shadow-[0_16px_48px_rgba(0,0,0,0.12)] transition-all duration-300"
            >
              <div class="grid lg:grid-cols-2">
                {/* Image */}
                <div class="relative aspect-[16/9] lg:aspect-auto overflow-hidden bg-navy-100">
                  {imgUrl ? (
                    <img
                      src={imgUrl}
                      alt={featured.title}
                      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                      loading="eager"
                    />
                  ) : (
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-navy-300">
                      <i class="fa-regular fa-image text-[48px]"></i>
                    </div>
                  )}
                  {/* Featured badge */}
                  <div class="absolute top-[16px] left-[16px] flex items-center gap-[6px] bg-orange-600 text-white text-[11px] font-bold uppercase tracking-wider px-[12px] py-[5px] rounded-full shadow-md">
                    <i class="fa-solid fa-star text-[9px]"></i>Artikel Pilihan
                  </div>
                </div>

                {/* Content */}
                <div class="p-[32px] lg:p-[40px] flex flex-col justify-center">
                  {date && (
                    <p class="text-orange-500 text-[12px] font-semibold mb-[12px] flex items-center gap-[6px]">
                      <i class="fa-regular fa-calendar"></i>{date}
                    </p>
                  )}
                  <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-[26px] max-lg:text-[22px] font-bold leading-snug group-hover:text-orange-600 transition-colors line-clamp-3">
                    {featured.title}
                  </h2>
                  {excerpt && (
                    <p class="text-navy-500 text-[15px] leading-relaxed mt-[14px] line-clamp-3">{excerpt}</p>
                  )}
                  <span class="inline-flex items-center gap-[6px] text-orange-600 font-semibold text-[14px] mt-[20px] group-hover:gap-[10px] transition-all">
                    Baca selengkapnya <i class="fa-solid fa-arrow-right text-[11px]"></i>
                  </span>
                </div>
              </div>
            </a>
          );
        })()}

        {/* ------- Grid: section header ------- */}
        {!fetchError && gridArticles.length > 0 && (
          <div class="mb-[32px]">
            <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-[24px] font-bold">Artikel Lainnya</h2>
            <div class="w-[40px] h-[3px] bg-orange-500 rounded-full mt-[10px]"></div>
          </div>
        )}

        {/* ------- Article grid ------- */}
        {!fetchError && gridArticles.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[28px]">
            {gridArticles.map((article) => {
              const imgUrl = article.featured_image
                ? getAssetUrl(article.featured_image, { width: 600, height: 340, format: "webp", quality: 85 })
                : null;
              const date = formatDate(article.publish_date);
              const excerpt = getExcerpt(article.content);
              return (
                <a
                  href={"/artikel/" + article.slug}
                  class="group flex flex-col bg-white rounded-[var(--radius-lg)] shadow-[var(--shadow-soft)] overflow-hidden no-underline hover:shadow-[0_12px_36px_rgba(0,0,0,0.12)] transition-all duration-300 hover:-translate-y-[6px]"
                >
                  {/* Image */}
                  <div class="relative aspect-[16/9] overflow-hidden bg-navy-100">
                    {imgUrl ? (
                      <img
                        src={imgUrl}
                        alt={article.title}
                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                      />
                    ) : (
                      <div class="absolute inset-0 flex flex-col items-center justify-center text-navy-300">
                        <i class="fa-regular fa-image text-[36px]"></i>
                      </div>
                    )}
                    {/* Date badge */}
                    {date && (
                      <div class="absolute top-[12px] right-[12px] bg-white/95 backdrop-blur-sm text-navy-700 text-[11px] font-semibold px-[10px] py-[4px] rounded-full shadow-sm">
                        <i class="fa-regular fa-calendar mr-[4px] text-orange-500"></i>{date}
                      </div>
                    )}
                  </div>

                  {/* Card body */}
                  <div class="flex flex-col flex-1 p-[20px]">
                    <h3 class="font-[family-name:var(--font-display)] text-navy-800 text-[17px] font-bold leading-snug group-hover:text-orange-600 transition-colors line-clamp-2">
                      {article.title}
                    </h3>
                    {excerpt && (
                      <p class="text-navy-400 text-[13px] leading-relaxed mt-[8px] line-clamp-3">{excerpt}</p>
                    )}
                    <span class="inline-flex items-center gap-[5px] text-orange-600 font-semibold text-[13px] mt-auto pt-[14px] group-hover:gap-[8px] transition-all">
                      Baca selengkapnya <span class="text-[12px]">→</span>
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        )}

      </div>
    </section>

    <!-- ================================================================== -->
    <!-- CTA BAND -->
    <!-- ================================================================== -->
    {!fetchError && articles.length > 0 && (
      <section class="bg-navy-900 relative overflow-hidden">
        <!-- Decorative glow -->
        <div class="absolute top-0 right-[10%] w-[300px] h-[300px] rounded-full bg-orange-600/8 blur-[80px] pointer-events-none"></div>

        <div class="wrap py-[48px] max-lg:py-[36px] flex items-center justify-between gap-[32px] max-lg:flex-col max-lg:text-center relative z-10">
          <div>
            <h2 class="font-[family-name:var(--font-display)] text-white text-[22px] max-lg:text-[19px] font-bold leading-snug">
              Ingin Merencanakan Perjalanan Impian?
            </h2>
            <p class="text-white/55 text-[14px] mt-[6px]">Hubungi kami untuk konsultasi gratis dan penawaran terbaik.</p>
          </div>
          <a
            href="/kontak"
            class="inline-flex items-center gap-[8px] bg-orange-600 text-white px-[28px] py-[13px] rounded-[var(--radius-sm)] font-semibold text-[14px] no-underline shrink-0 transition-all duration-200 hover:bg-orange-500 hover:scale-[1.02] active:scale-[0.98] shadow-[0_4px_14px_rgba(234,88,12,0.3)]"
          >
            <i class="fa-solid fa-envelope text-[14px]"></i>Hubungi Kami
          </a>
        </div>
      </section>
    )}
  </main>
</Layout>
