---
// Voda Tour & Event — Halaman Pencarian
// Static shell — semua state dikelola client-side oleh initSearchPage()

import Layout from "../layouts/Layout.astro";
import SearchForm from "../components/SearchForm.astro";
import { getDestinations, getActivityTypes } from "../lib/directus";
import type { Destination, ActivityType } from "../types/directus";

let destinations: Destination[] = [];
let activityTypes: ActivityType[] = [];

try {
  [destinations, activityTypes] = await Promise.all([
    getDestinations("slug,name"),
    getActivityTypes(),
  ]);
} catch {
  // halaman masih bisa render — JS client yang handle pencarian
}
---

<Layout
  title="Cari Paket Wisata | Voda Tour & Event"
  description="Temukan paket wisata dan event terbaik untuk perjalanan Anda bersama Voda Tour & Event."
  active="paket"
>
  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden bg-gradient-to-br from-navy-900 via-navy-800 to-[#0A2A3D] py-[60px] max-lg:py-[45px]">
      <div class="absolute top-[-80px] right-[-40px] w-[250px] h-[250px] rounded-full bg-orange-500/8 blur-[70px]" aria-hidden="true"></div>
      <div class="absolute bottom-[-60px] left-[-30px] w-[180px] h-[180px] rounded-full bg-white/5 blur-[60px]" aria-hidden="true"></div>

      <div class="wrap relative z-10">
        <div class="max-w-[700px]">
          <span class="text-[11px] font-semibold text-orange-400 uppercase tracking-[0.15em]">Pencarian</span>
          <h1 class="font-[family-name:var(--font-display)] text-white text-[32px] max-lg:text-[24px] font-bold mt-[6px]">Cari Paket Wisata</h1>
          <p class="text-white/60 text-[14px] mt-[6px]" id="search-subtitle">
            Temukan paket perjalanan dan event sesuai keinginanmu.
          </p>
        </div>
        <div class="mt-[28px] max-w-[860px]">
          <SearchForm destinations={destinations} activityTypes={activityTypes} />
        </div>
      </div>
    </section>

    <!-- RESULTS CONTAINER — always rendered, JS handles content -->
    <section class="py-[50px] max-lg:py-[35px]">
      <div class="wrap">
        <!-- Loading state (visible initially, JS replaces it) -->
         <!-- Search count -->         <div id="search-count" class="text-navy-400 text-[13px] mb-[20px]"></div>          <!-- Active filter tags -->         <div id="filter-tags" class="flex flex-wrap gap-[8px] mb-[20px]"></div>
        <div id="search-results" class="text-center py-[80px]">
          <div class="w-[80px] h-[80px] rounded-full bg-navy-50 flex items-center justify-center mx-auto mb-[20px]">
            <i class="fa-solid fa-magnifying-glass text-[32px] text-navy-300"></i>
          </div>
          <h2 class="font-[family-name:var(--font-display)] text-navy-500 text-[20px] font-semibold">Mulai Pencarian</h2>
          <p class="text-navy-400 text-[14px] mt-[6px] max-w-[400px] mx-auto">
            Gunakan form di atas untuk mencari paket wisata berdasarkan kata kunci, tanggal, kegiatan, atau jumlah peserta.
          </p>
          <div class="flex flex-wrap justify-center gap-[10px] mt-[24px]">
            <a href="/paket" class="inline-flex items-center gap-[6px] text-orange-600 text-[13px] font-semibold no-underline hover:underline">
              <i class="fa-solid fa-gift"></i>Lihat Semua Paket
            </a>
            <a href="/destinasi" class="inline-flex items-center gap-[6px] text-navy-500 text-[13px] font-semibold no-underline hover:underline">
              <i class="fa-solid fa-location-dot"></i>Jelajahi Destinasi
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<!-- Client-side Templates -->
<template id="package-card-template">
  <a href="#" class="group relative block w-full min-h-[340px] flex flex-col justify-end rounded-[var(--radius-md)] shadow-[var(--shadow-soft)] overflow-hidden no-underline transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[var(--shadow-card)]">
    <div class="absolute inset-0 bg-navy-950 z-0">
      <img src="" alt="" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105 group-hover:rotate-1 hidden" loading="lazy" data-img />
      <div class="w-full h-full flex flex-col items-center justify-center text-white/20" data-no-img>
        <i class="fa-regular fa-image text-5xl"></i>
        <span class="text-xs mt-2 font-medium">No Image</span>
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/85 to-navy-950/20"></div>
    </div>
    <div class="absolute top-4 left-4 z-10 w-10 h-10 bg-white rounded-full flex items-center justify-center text-navy-800 text-base shadow-[0_4px_12px_rgba(0,0,0,0.15)]">
      <i class="fa-solid fa-map-marked-alt" data-icon></i>
    </div>
    <div class="relative z-10 p-5">
      <h3 class="font-[family-name:var(--font-display)] text-white font-semibold text-base leading-tight line-clamp-2" data-title></h3>
      <p class="text-white/70 text-sm leading-relaxed mt-1.5 line-clamp-2" data-desc></p>
      <p class="text-xs text-white/50 mt-2 hidden" data-dest><i class="fa-solid fa-location-dot text-orange-400 text-[10px] mr-1"></i><span data-dest-text></span></p>
      <div class="border-t border-dashed border-white/15 my-3.5"></div>
      <div class="flex items-center justify-between">
        <div>
          <div data-price-wrapper class="hidden">
            <span class="text-xs text-white/50 font-medium block leading-none">Mulai dari</span>
            <span class="font-[family-name:var(--font-display)] text-orange-400 font-bold text-base leading-tight" data-price></span>
          </div>
          <div data-no-price-wrapper class="hidden">
            <span class="text-xs text-white/60 italic">Hubungi kami</span>
          </div>
        </div>
        <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-navy-950 text-sm transition-all duration-200 group-hover:bg-orange-500 group-hover:text-white group-hover:scale-110">
          <i class="fa-solid fa-arrow-right"></i>
        </div>
      </div>
    </div>
  </a>
</template>

<template id="package-skeleton-template">
  <div class="rounded-[var(--radius-md)] bg-navy-50 animate-pulse overflow-hidden">
    <div class="h-40 bg-navy-100"></div>
    <div class="p-5 space-y-2.5">
      <div class="h-4 bg-navy-100 rounded w-[70%]"></div>
      <div class="h-3 bg-navy-50 rounded w-[50%]"></div>
      <div class="flex justify-between pt-2.5 border-t border-navy-100">
        <div class="h-3 bg-navy-50 rounded w-16"></div>
        <div class="h-3 bg-navy-50 rounded w-20"></div>
      </div>
    </div>
  </div>
</template>

<script>
import { initSearchPage } from "../lib/search";
window.__DIRECTUS_URL__ = import.meta.env.PUBLIC_DIRECTUS_URL || "http://localhost:8055";
document.addEventListener("DOMContentLoaded", initSearchPage);
</script>