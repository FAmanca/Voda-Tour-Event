---
// Voda Tour & Event — Halaman Pencarian
// Static shell — semua state dikelola client-side oleh initSearchPage()

import Layout from "../layouts/Layout.astro";
import SearchForm from "../components/SearchForm.astro";
import { getDestinations, getActivityTypes } from "../lib/directus";
import type { Destination, ActivityType } from "../types/directus";

let destinations: Destination[] = [];
let activityTypes: ActivityType[] = [];

try {
  [destinations, activityTypes] = await Promise.all([
    getDestinations("slug,name"),
    getActivityTypes(),
  ]);
} catch {
  // halaman masih bisa render — JS client yang handle pencarian
}
---

<Layout
  title="Cari Paket Wisata | Voda Tour & Event"
  description="Temukan paket wisata dan event terbaik untuk perjalanan Anda bersama Voda Tour & Event."
  active="paket"
>
  <main>
    <!-- HERO -->
    <section class="relative bg-gradient-to-br from-navy-900 via-navy-800 to-[#0A2A3D] py-[60px] max-lg:py-[45px]">
      <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute top-[-80px] right-[-40px] w-[250px] h-[250px] rounded-full bg-orange-500/8 blur-[70px]"></div>
        <div class="absolute bottom-[-60px] left-[-30px] w-[180px] h-[180px] rounded-full bg-white/5 blur-[60px]"></div>
      </div>

      <div class="wrap relative z-10">
        <div class="max-w-[700px]">
          <span class="text-[11px] font-semibold text-orange-400 uppercase tracking-[0.15em]">Pencarian</span>
          <h1 class="font-[family-name:var(--font-display)] text-white text-[32px] max-lg:text-[24px] font-bold mt-[6px]">Cari Paket Wisata</h1>
          <p class="text-white/60 text-[14px] mt-[6px]" id="search-subtitle">
            Temukan paket perjalanan dan event sesuai keinginanmu.
          </p>
        </div>
        <div class="mt-[36px] w-full">
          <SearchForm destinations={destinations} activityTypes={activityTypes} />
        </div>
      </div>
    </section>

    <!-- RESULTS CONTAINER — always rendered, JS handles content -->
    <section class="py-[60px] max-lg:py-[40px] bg-slate-50 min-h-[500px]">
      <div class="wrap">
        <!-- Loading state (visible initially, JS replaces it) -->
         <!-- Search count -->         <div id="search-count" class="text-navy-400 text-[14px] font-medium mb-[16px]"></div>          <!-- Active filter tags -->         <div id="filter-tags" class="flex flex-wrap gap-[10px] mb-[24px]"></div>
        <div id="search-results" class="text-center py-[100px]">
          <div class="w-[90px] h-[90px] rounded-full bg-white shadow-xl shadow-navy-900/5 flex items-center justify-center mx-auto mb-[24px] border border-navy-100">
            <i class="fa-solid fa-magnifying-glass text-[36px] text-navy-300"></i>
          </div>
          <h2 class="font-[family-name:var(--font-display)] text-navy-900 text-[24px] font-bold">Jelajahi Dunia Bersama Kami</h2>
          <p class="text-navy-500 text-[15px] mt-[10px] max-w-[420px] mx-auto leading-relaxed">
            Gunakan kotak pencarian di atas untuk menemukan paket liburan, destinasi impian, atau event perusahaan.
          </p>
          <div class="flex flex-wrap justify-center gap-[16px] mt-[32px]">
            <a href="/paket" class="inline-flex items-center justify-center px-[24px] h-[44px] bg-orange-600 hover:bg-orange-500 text-white rounded-[12px] text-[14px] font-semibold transition-all hover:-translate-y-[2px] shadow-lg shadow-orange-500/30">
              Lihat Semua Paket
            </a>
            <a href="/destinasi" class="inline-flex items-center justify-center px-[24px] h-[44px] bg-white hover:bg-navy-50 text-navy-800 rounded-[12px] text-[14px] font-semibold transition-all border border-navy-100 hover:border-navy-200">
              Jelajahi Destinasi
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<!-- Client-side Templates -->
<template id="package-card-template">
  <a href="#" class="group relative block w-full h-[400px] flex flex-col justify-end rounded-[20px] shadow-[0_8px_30px_rgba(0,0,0,0.08)] overflow-hidden no-underline transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.12)]">
    <div class="absolute inset-0 bg-navy-950 z-0">
      <img src="" alt="" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110 hidden" loading="lazy" data-img />
      <div class="w-full h-full flex flex-col items-center justify-center text-white/20" data-no-img>
        <i class="fa-regular fa-image text-5xl"></i>
        <span class="text-xs mt-2 font-medium">No Image</span>
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/70 to-transparent"></div>
    </div>
    <div class="absolute top-5 left-5 z-10 px-3 py-1.5 bg-white/90 backdrop-blur-md rounded-full flex items-center justify-center text-navy-900 font-semibold text-xs shadow-lg">
      <i class="fa-solid fa-map-marked-alt mr-1.5 text-orange-500" data-icon></i>
      <span data-dest-text></span>
    </div>
    <div class="relative z-10 p-6">
      <h3 class="font-[family-name:var(--font-display)] text-white font-bold text-[20px] leading-tight line-clamp-2 drop-shadow-md" data-title></h3>
      <p class="text-white/80 text-[14px] leading-relaxed mt-2 line-clamp-2" data-desc></p>
      <div class="w-full h-[1px] bg-white/20 my-4"></div>
      <div class="flex items-center justify-between">
        <div>
          <div data-price-wrapper class="hidden">
            <span class="text-[11px] text-white/70 font-semibold uppercase tracking-wider block mb-1">Mulai dari</span>
            <span class="font-[family-name:var(--font-display)] text-orange-400 font-bold text-[18px] leading-none" data-price></span>
          </div>
          <div data-no-price-wrapper class="hidden">
            <span class="text-[13px] text-white/80 italic">Hubungi kami untuk harga</span>
          </div>
        </div>
        <div class="w-11 h-11 bg-orange-500 rounded-full flex items-center justify-center text-white text-sm transition-transform duration-300 group-hover:bg-orange-400 group-hover:scale-110 shadow-lg shadow-orange-500/30">
          <i class="fa-solid fa-arrow-right -rotate-45 group-hover:rotate-0 transition-transform duration-300"></i>
        </div>
      </div>
    </div>
  </a>
</template>

<template id="package-skeleton-template">
  <div class="w-full h-[400px] rounded-[20px] bg-white shadow-sm border border-slate-100 animate-pulse overflow-hidden flex flex-col">
    <div class="h-[220px] bg-slate-200 w-full relative">
      <div class="absolute top-5 left-5 h-7 w-24 bg-slate-300 rounded-full"></div>
    </div>
    <div class="p-6 flex-1 flex flex-col justify-end">
      <div class="h-6 bg-slate-200 rounded-md w-3/4 mb-3"></div>
      <div class="h-4 bg-slate-100 rounded-md w-full mb-2"></div>
      <div class="h-4 bg-slate-100 rounded-md w-5/6"></div>
      <div class="w-full h-[1px] bg-slate-100 my-4"></div>
      <div class="flex justify-between items-center">
        <div>
          <div class="h-3 bg-slate-200 rounded-md w-16 mb-2"></div>
          <div class="h-5 bg-slate-200 rounded-md w-24"></div>
        </div>
        <div class="h-11 w-11 bg-slate-200 rounded-full"></div>
      </div>
    </div>
  </div>
</template>

<script>
import { initSearchPage } from "../lib/search";
window.__DIRECTUS_URL__ = import.meta.env.PUBLIC_DIRECTUS_URL || "http://localhost:8055";
document.addEventListener("DOMContentLoaded", initSearchPage);
</script>