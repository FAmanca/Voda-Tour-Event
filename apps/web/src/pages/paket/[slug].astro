---
import Layout from "../../layouts/Layout.astro";
import WaButton from "../../components/WaButton.astro";
import ItineraryTimeline from "../../components/ItineraryTimeline.astro";
import PriceTable from "../../components/PriceTable.astro";
import AdditionalTable from "../../components/AdditionalTable.astro";
import GallerySection from "../../components/GallerySection.astro";
import CTABand from "../../components/CTABand.astro";
import PackageHero from "../../components/PackageHero.astro";
import PackageFacilities from "../../components/PackageFacilities.astro";
import PackageSimilar from "../../components/PackageSimilar.astro";
import { getAssetUrl, getSettings } from "../../lib/directus";
import { getStartingPrice, formatPrice, getPriceRange } from "../../lib/utils";

import type { Package, ActivityType } from "../../types/directus";

// SSR — no getStaticPaths needed

const { slug } = Astro.params;
const DIRECTUS_URL = import.meta.env.DIRECTUS_URL || "http://localhost:8055";
let pkg: Package | null = null;
let similarPackages: Package[] = [];
let fetchError = false;

try {
  const packageRes = await fetch(DIRECTUS_URL + "/items/packages?fields=*,destination_id.*&filter[slug][_eq]=" + slug + "&filter[status][_eq]=published");
  if (packageRes.ok) { const packageJson = await packageRes.json(); pkg = packageJson.data?.[0] || null; }
  if (pkg) {
    const destinationId = typeof pkg.destination_id === "object" ? pkg.destination_id?.id : pkg.destination_id;
    if (destinationId) {
      const similarRes = await fetch(DIRECTUS_URL + "/items/packages?fields=*,destination_id.*&limit=3&filter[id][_neq]=" + pkg.id + "&filter[destination_id][_eq]=" + destinationId + "&filter[status][_eq]=published&sort=-id");
      if (similarRes.ok) { const similarJson = await similarRes.json(); similarPackages = similarJson.data || []; }
    }
  }
} catch (error) { fetchError = true; if (import.meta.env.DEV) console.error("Error fetching package:", error); }

let settings: Record<string, string> = {};
try {
  settings = await getSettings();
} catch {}
const waNumber = settings.wa_number || settings.whatsapp || "6282112345678";

const destinationName = pkg ? (typeof pkg.destination_id === "object" ? pkg.destination_id?.name : "") : "";
const destinationSlug = pkg ? (typeof pkg.destination_id === "object" ? pkg.destination_id?.slug : "") : "";
// Activity types untuk badges (via junction table)
const packageActivityTypes: ActivityType[] = [];
if (pkg) {
  try {
    const activityTypeRes = await fetch(DIRECTUS_URL + "/items/packages_activity_types?fields=activity_type_id.*&filter[package_id][_eq]=" + pkg.id + "&limit=10");
    if (activityTypeRes.ok) {
      const activityTypeJson = await activityTypeRes.json();
      (activityTypeJson.data || []).forEach(function(junction) {
        if (junction.activity_type_id) packageActivityTypes.push(junction.activity_type_id);
      });
    }
  } catch (err) { if (import.meta.env.DEV) console.error("Error fetching activity types:", err); }
}
const startingPrice = pkg?.price_tiers ? getStartingPrice(pkg.price_tiers) : null;
const priceRange = pkg?.price_tiers ? getPriceRange(pkg.price_tiers) : null;
---


<Layout title={pkg ? pkg.name + " | Paket Voda Tour & Event" : "Paket Tidak Ditemukan"}
  description={pkg?.description || ""}
  image={pkg?.gallery?.[0] ? (import.meta.env.PUBLIC_DIRECTUS_URL || "http://localhost:8055") + "/assets/" + pkg.gallery[0] + "?width=1200&height=630&format=webp" : ""}
  canonical={pkg ? "https://vodatrip.id/paket/" + pkg.slug : ""}
  jsonld={pkg ? JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": pkg.name,
    "description": pkg.description,
    "image": pkg.gallery?.length ? pkg.gallery.map(g => (import.meta.env.PUBLIC_DIRECTUS_URL || "http://localhost:8055") + "/assets/" + g + "?width=800&format=webp") : [],
    "url": "https://vodatrip.id/paket/" + pkg.slug,
    "brand": { "@type": "Brand", "name": "Voda Tour & Event" },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "IDR",
      "lowPrice": priceRange?.min ?? 0,
      "highPrice": priceRange?.max ?? 0,
      "offerCount": pkg.price_tiers ? pkg.price_tiers.length : 0,
      "availability": "https://schema.org/InStock"
    }
  }) : ""}
  active="paket">
  <main>
    {fetchError && (
      <section class="bg-navy-900"><div class="wrap py-[120px] text-center text-white/80">
        <i class="fa-solid fa-triangle-exclamation text-[40px] text-orange-500 block mb-[16px]"></i>
        <p>Gagal memuat halaman.</p>
      </div></section>
    )}

    {!fetchError && !pkg && (
      <section class="bg-navy-900"><div class="wrap py-[120px] text-center">
        <i class="fa-regular fa-face-frown text-[56px] text-white/30 block mb-[20px]"></i>
        <h1 class="font-[family-name:var(--font-display)] text-white text-[28px] font-bold">Paket Tidak Ditemukan</h1>
        <p class="text-white/60 mt-[10px]">Halaman tidak tersedia.</p>
        <a href="/paket" class="inline-flex items-center gap-[8px] mt-[20px] text-orange-600 font-semibold text-[14px] hover:underline"><i class="fa-solid fa-arrow-left"></i> Kembali</a>
      </div></section>
    )}

    {pkg && <>
      <!-- ===== HERO ===== -->
      <PackageHero 
        pkg={pkg}
        destinationName={destinationName}
        destinationSlug={destinationSlug}
        startingPrice={startingPrice}
        packageActivityTypes={packageActivityTypes}
        waNumber={waNumber}
      />

      <!-- ===== DESCRIPTION ===== -->
      {pkg.description && (
        <section class="py-16 max-lg:py-12"><div class="wrap">
          <div class="max-w-3xl">
            <span class="text-xs font-semibold text-orange-600 uppercase tracking-widest">Tentang Paket Ini</span>
            <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-3xl max-lg:text-2xl font-bold mt-2">{pkg.name}</h2>
            <div class="w-10 h-1 bg-orange-500 rounded-full mt-3"></div>
            <div class="text-navy-600 text-base leading-relaxed mt-4" set:html={pkg.description}></div>
          </div>
        </div></section>
      )}

      <!-- ===== ITINERARY ===== -->
      {pkg.itinerary && pkg.itinerary.length > 0 && (
        <section class="bg-navy-50 py-[70px] max-lg:py-[50px]"><div class="wrap">
          <div class="text-center mb-[40px]">
            <span class="text-[11px] font-semibold text-orange-600 uppercase tracking-[0.15em]">Itinerary</span>
            <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-[26px] max-lg:text-[22px] font-bold mt-[8px]">Rencana Perjalanan</h2>
            <p class="text-navy-500 text-[14px] mt-[6px]">Jadwal perjalanan selama {pkg.duration}.</p>
          </div>
          <div class="max-w-[700px] mx-auto">
            <ItineraryTimeline itinerary={pkg.itinerary} />
          </div>
        </div></section>
      )}

      <!-- ===== FACILITIES ===== -->
      {pkg.facilities && pkg.facilities.length > 0 && (
        <PackageFacilities facilities={pkg.facilities} />
      )}

      <!-- ===== PRICE & ADDONS ===== -->
      {(pkg.price_tiers?.length > 0 || pkg.addons?.length > 0) && (
        <section class="bg-navy-50 py-[70px] max-lg:py-[50px]"><div class="wrap">
          <div class="text-center mb-[36px]">
            <span class="text-[11px] font-semibold text-orange-600 uppercase tracking-[0.15em]">Harga</span>
            <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-[26px] max-lg:text-[22px] font-bold mt-[8px]">Harga Paket & Tambahan</h2>
            <p class="text-navy-500 text-[14px] mt-[6px]">Harga per orang berdasarkan jumlah peserta</p>
          </div>
          <div class="max-w-[1140px] mx-auto flex flex-col gap-[32px]">
            {pkg.price_tiers && pkg.price_tiers.length > 0 && (
              <PriceTable priceTiers={pkg.price_tiers} />
            )}
            
            {pkg.addons && pkg.addons.length > 0 && (
              <div class="max-w-[800px] mx-auto w-full">
                <AdditionalTable addons={pkg.addons} />
              </div>
            )}

            <div class="max-w-[800px] mx-auto w-full mt-[16px] flex items-start gap-[8px] text-navy-400 text-[12px] bg-white rounded-[var(--radius-sm)] p-[12px] border border-[--color-line]">
              <i class="fa-solid fa-circle-info text-orange-400 mt-[2px] text-[12px]"></i>
              <span>Harga dapat berubah sesuai musim dan ketersediaan. Hubungi kami untuk penawaran terbaik.</span>
            </div>
          </div>
        </div></section>
      )}

      <!-- ===== GALLERY ===== -->
      {pkg.gallery && pkg.gallery.length > 1 && (
        <section class="py-[70px] max-lg:py-[50px]"><div class="wrap">
          <div class="text-center mb-[36px]">
            <span class="text-[11px] font-semibold text-orange-600 uppercase tracking-[0.15em]">Galeri</span>
            <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-[26px] max-lg:text-[22px] font-bold mt-[8px]">Foto {pkg.name}</h2>
            <p class="text-navy-500 text-[14px] mt-[6px]">{pkg.gallery.length} foto tersedia</p>
          </div>
          <GallerySection images={pkg.gallery} columns={3} />
        </div></section>
      )}

      <!-- ===== CTA BAND ===== -->
      <section class="relative overflow-hidden bg-gradient-to-br from-navy-900 via-navy-800 to-[#0A2A3D] py-[70px]"><div class="wrap text-center relative z-10">
        <div class="absolute top-[-60px] left-[-20px] w-[180px] h-[180px] rounded-full bg-orange-500/8 blur-[60px]" aria-hidden="true"></div>
        <h2 class="font-[family-name:var(--font-display)] text-white text-[26px] max-lg:text-[22px] font-bold">Tertarik dengan Paket Ini?</h2>
        <p class="text-white/60 text-[14px] mt-[8px] max-w-[400px] mx-auto">Hubungi kami via WhatsApp untuk konsultasi gratis.</p>
        <div class="mt-[24px] flex flex-wrap justify-center gap-[12px]">
          <WaButton phone={waNumber} variant="primary" message={encodeURIComponent(`Halo Voda Tour & Event, saya tertarik dengan paket ${pkg.name}.`)}>Pesan via WhatsApp</WaButton>
          <a href="/kontak" class="inline-flex items-center gap-[8px] bg-white/10 text-white rounded-[999px] px-[24px] py-[12px] font-semibold text-[13px] no-underline border border-white/20 transition-all hover:bg-white/20">
            <i class="fa-regular fa-envelope"></i>Hubungi Kami
          </a>
        </div>
      </div></section>

      <!-- ===== SIMILAR PACKAGES ===== -->
      {similarPackages.length > 0 && (
        <PackageSimilar 
          similarPackages={similarPackages} 
          destinationName={destinationName} 
          destinationSlug={destinationSlug} 
        />
      )}

      <CTABand ctaUrl={"https://wa.me/" + waNumber + "?text=Halo%20Voda%20Tour%20%26%20Event%2C%20saya%20tertarik%20untuk%20konsultasi%20mengenai%20trip%20dan%20event."} />
    </>}
  </main>
</Layout>