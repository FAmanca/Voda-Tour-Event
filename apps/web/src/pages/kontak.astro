---
import Layout from "../layouts/Layout.astro";
import WaButton from "../components/WaButton.astro";

import { getSettings } from "../lib/directus";
import { DEFAULT_WA_NUMBER, DEFAULT_EMAIL, DEFAULT_ADDRESS } from "../lib/constants";

let settings: Record<string, string> = {};
try {
  settings = await getSettings();
} catch {}

const waNum = settings.wa_number || settings.whatsapp || DEFAULT_WA_NUMBER;
const email = settings.email || DEFAULT_EMAIL;
const address = settings.address || DEFAULT_ADDRESS;
const ig = settings.instagram || "voda.event";
const fb = settings.facebook || "voda.event";
const yt = settings.youtube || "@vodatrip";
const tiktok = settings.tiktok || "@voda.event";
const threads = settings.threads || "@voda.event";
const x = settings.x || "voda_event";
---

<Layout title="Kontak | Voda Tour & Event" description="Hubungi Voda Tour & Event untuk konsultasi dan pemesanan." active="kontak">
  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-navy-900 via-navy-800 to-[#0F2C4C] py-[80px] max-lg:py-[50px]">
      <div class="absolute top-[-40px] right-[-20px] w-[200px] h-[200px] rounded-full bg-orange-500/10 blur-[70px]" aria-hidden="true"></div>
      <div class="absolute bottom-[-30px] left-[-40px] w-[160px] h-[160px] rounded-full bg-teal-400/10 blur-[50px]" aria-hidden="true"></div>
      <div class="wrap relative z-10 text-center">
        <div class="inline-flex items-center gap-[8px] bg-white/10 backdrop-blur-sm text-orange-400 text-[12px] font-semibold px-[14px] py-[5px] rounded-full mb-[16px]">
          <i class="fa-solid fa-headset text-[10px]"></i>KONTAK
        </div>
        <h1 class="font-[family-name:var(--font-display)] text-white text-[38px] max-lg:text-[28px] font-bold mt-[12px]">Hubungi Kami</h1>
        <p class="text-white/65 text-[16px] max-lg:text-[14px] mt-[8px] max-w-[450px] mx-auto">Kami siap membantu Anda merencanakan perjalanan dan event terbaik.</p>
      </div>
    </section>

    <section class="py-[70px] max-lg:py-[50px]"><div class="wrap">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-[50px]">
        <div class="lg:col-span-2">
          <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-[24px] font-bold">Informasi Kontak</h2>
          <p class="text-navy-500 text-[14px] mt-[6px]">Jangan ragu untuk menghubungi kami.</p>
          <div class="space-y-[20px] mt-[28px]">
            {waNum && (
              <div class="flex items-start gap-[16px] group">
                <div class="w-[48px] h-[48px] rounded-full bg-green-50 flex items-center justify-center text-green-600 text-[20px] shrink-0 group-hover:bg-green-100"><i class="fa-brands fa-whatsapp"></i></div>
                <div class="pt-[4px]">
                  <p class="text-navy-700 font-semibold text-[13px]">WhatsApp</p>
                  <a href={"https://wa.me/" + waNum + "?text=Halo%20Voda%20Tour%20%26%20Event%2C%20saya%20tertarik%20untuk%20konsultasi%20mengenai%20layanan%20Anda."} target="_blank" class="text-orange-600 text-[14px] hover:underline font-medium">{waNum}</a>
                </div>
              </div>
            )}
            {email && (
              <div class="flex items-start gap-[16px] group">
                <div class="w-[48px] h-[48px] rounded-full bg-blue-50 flex items-center justify-center text-blue-600 text-[20px] shrink-0 group-hover:bg-blue-100"><i class="fa-solid fa-envelope"></i></div>
                <div class="pt-[4px]">
                  <p class="text-navy-700 font-semibold text-[13px]">Email</p>
                  <a href={"mailto:" + email} class="text-orange-600 text-[14px] hover:underline font-medium">{email}</a>
                </div>
              </div>
            )}
            {address && (
              <div class="flex items-start gap-[16px] group">
                <div class="w-[48px] h-[48px] rounded-full bg-navy-50 flex items-center justify-center text-navy-600 text-[20px] shrink-0 group-hover:bg-navy-100"><i class="fa-solid fa-location-dot"></i></div>
                <div class="pt-[4px]">
                  <p class="text-navy-700 font-semibold text-[13px]">Alamat</p>
                  <p class="text-navy-500 text-[13px] leading-relaxed">{address}</p>
                </div>
              </div>
            )}
          </div>
          <!-- {(ig || fb || yt || tiktok || threads || x) && (
            <div class="mt-[32px] pt-[24px] border-t border-[--color-line]">
              <p class="text-navy-700 font-semibold text-[13px] mb-[12px]">Ikuti Kami</p>
              <div class="flex flex-wrap gap-[10px]">
                {fb && <a href={"https://facebook.com/" + fb} aria-label="Facebook" target="_blank" class="w-[42px] h-[42px] rounded-full bg-navy-50 flex items-center justify-center text-navy-600 hover:bg-[#1877F2] hover:text-white transition-all no-underline"><i class="fa-brands fa-facebook-f"></i></a>}
                {yt && <a href={"https://youtube.com/" + yt} aria-label="YouTube" target="_blank" class="w-[42px] h-[42px] rounded-full bg-navy-50 flex items-center justify-center text-navy-600 hover:bg-[#FF0000] hover:text-white transition-all no-underline"><i class="fa-brands fa-youtube"></i></a>}
                {ig && <a href={"https://instagram.com/" + ig} aria-label="Instagram" target="_blank" class="w-[42px] h-[42px] rounded-full bg-navy-50 flex items-center justify-center text-navy-600 hover:bg-[#E4405F] hover:text-white transition-all no-underline"><i class="fa-brands fa-instagram"></i></a>}
                {tiktok && <a href={"https://tiktok.com/" + tiktok} aria-label="TikTok" target="_blank" class="w-[42px] h-[42px] rounded-full bg-navy-50 flex items-center justify-center text-navy-600 hover:bg-[#000000] hover:text-white transition-all no-underline"><i class="fa-brands fa-tiktok"></i></a>}
                {threads && <a href={"https://threads.net/" + threads} aria-label="Threads" target="_blank" class="w-[42px] h-[42px] rounded-full bg-navy-50 flex items-center justify-center text-navy-600 hover:bg-[#000000] hover:text-white transition-all no-underline"><i class="fa-brands fa-threads"></i></a>}
                {x && <a href={"https://x.com/" + x} aria-label="X" target="_blank" class="w-[42px] h-[42px] rounded-full bg-navy-50 flex items-center justify-center text-navy-600 hover:bg-[#000000] hover:text-white transition-all no-underline"><i class="fa-brands fa-x-twitter"></i></a>}
              </div>
            </div>
          )} -->
        </div>

        <div class="lg:col-span-3">
          <div class="bg-navy-50 rounded-[var(--radius-lg)] p-[36px] max-lg:p-[24px]">
            <h3 class="font-[family-name:var(--font-display)] text-navy-800 text-[20px] font-semibold">Ada Pertanyaan?</h3>
            <p class="text-navy-500 text-[14px] mt-[6px]">Tim kami siap membantu Anda. Klik tombol di bawah untuk chat via WhatsApp.</p>
            <div class="mt-[24px] space-y-[14px]">
              <div class="flex items-center gap-[12px] text-[13px] text-navy-600"><i class="fa-regular fa-circle-check text-orange-500"></i>Konsultasi gratis &amp; tanpa komitmen</div>
              <div class="flex items-center gap-[12px] text-[13px] text-navy-600"><i class="fa-regular fa-circle-check text-orange-500"></i>Respon cepat &amp; ramah</div>
              <div class="flex items-center gap-[12px] text-[13px] text-navy-600"><i class="fa-regular fa-circle-check text-orange-500"></i>Dapatkan penawaran custom</div>
              <div class="pt-[16px]">
                <WaButton phone={waNum} variant="primary" message={"Halo%20Voda%20Tour%20%26%20Event%2C%20saya%20ingin%20konsultasi%20tentang%20paket%20dan%20layanan%20Anda."}><i class="fa-brands fa-whatsapp"></i>Chat via WhatsApp</WaButton>
              </div>
              <p class="text-navy-400 text-[11px] mt-[8px]">Atau hubungi nomor <strong class="text-navy-600">{waNum}</strong> langsung.</p>
            </div>
          </div>
          <div class="mt-[20px] bg-navy-100 rounded-[var(--radius-lg)] h-[180px] flex items-center justify-center text-navy-400 text-[13px] gap-[8px]">
            <i class="fa-solid fa-map-location-dot text-[20px]"></i>
            <span>Peta lokasi (akan diintegrasikan)</span>
          </div>
        </div>
      </div>
    </div></section>
  </main>
</Layout>