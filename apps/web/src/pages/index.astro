---
// Voda Tour & Event — Landing Page (index.astro)
// SSR fetch from Directus, then render all sections

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import FeatureStrip from "../components/FeatureStrip.astro";
import SectionHeader from "../components/SectionHeader.astro";
import PackageGrid from "../components/PackageGrid.astro";
import StatsBar from "../components/StatsBar.astro";
import CTABand from "../components/CTABand.astro";

// -----------------------------------------------------------------------
// SSR fetch dari Directus
// -----------------------------------------------------------------------
const DIRECTUS_URL = import.meta.env.DIRECTUS_URL || "http://localhost:8055";

interface Setting {
  key: string;
  value: string;
}

let settings: Record<string, string> = {};
let destinations: any[] = [];
let packages: any[] = [];
let activityTypes: any[] = [];
let fetchError = false;

try {
  const base = `${DIRECTUS_URL}/items`;

  const [settingsRes, destRes, pkgRes, actRes] = await Promise.all([
    fetch(`${base}/settings`).then((r) => (r.ok ? r.json() : { data: [] })),
    fetch(`${base}/destinasi?limit=10&sort=name`).then((r) => (r.ok ? r.json() : { data: [] })),
    fetch(`${base}/paket?limit=4&sort=-id`).then((r) => (r.ok ? r.json() : { data: [] })),
    fetch(`${base}/activity_types?limit=20&sort=name`).then((r) => (r.ok ? r.json() : { data: [] })),
  ]);

  // Settings → flat key-value map
  if (settingsRes.data) {
    (settingsRes.data as Setting[]).forEach((s: Setting) => {
      settings[s.key] = s.value;
    });
  }

  destinations = destRes.data || [];
  packages = pkgRes.data || [];
  activityTypes = actRes.data || [];
} catch (e) {
  console.error("SSR fetch error:", e);
  fetchError = true;
}
---

<Layout
  title="Voda Tour & Event | Perjalanan Berkesan, Momen Tak Terlupakan"
  description="Solusi perjalanan wisata, gathering, dan event terbaik. Private tour, corporate gathering, dan outbound dengan pengalaman tak terlupakan."
  active="beranda"
>
  <main>
    <!-- 3.1 Hero + SearchCard -->
    <Hero
      settings={settings}
      destinations={destinations}
      activityTypes={activityTypes}
    />

    <!-- 3.2 FeatureStrip -->
    <FeatureStrip />

    <!-- 3.3 + 3.4 PackageGrid -->
    <section id="paket" class="wrap py-[90px] max-lg:py-[60px]">
      <SectionHeader
        eyebrow="PAKET PILIHAN"
        title="Destinasi & Paket Favorit"
        description="Temukan paket perjalanan dan event terbaik untuk momen spesial Anda."
        layout="default"
      />
      <div class="mt-[28px]">
        {fetchError ? (
          <div class="rounded-[var(--radius-md)] bg-red-50 border border-red-200 p-[16px] text-red-700 text-[14px]">
            <i class="fa-solid fa-circle-exclamation mr-[8px]"></i>
            Gagal memuat data. Pastikan Directus sudah berjalan.
          </div>
        ) : (
          <PackageGrid packages={packages} />
        )}
      </div>
    </section>

    <!-- 3.5 StatsBar + Testimonial -->
    <StatsBar />

    <!-- 3.6 CTABand -->
    <CTABand
      ctaLabel="Konsultasi Gratis"
      ctaUrl={`https://wa.me/${settings.whatsapp || "6282112345678"}?text=Halo%20Voda%20Tour%20%26%20Event%2C%20saya%20ingin%20tahu%20lebih%20lanjut%20tentang%20paket%20Anda.`}
    />
  </main>
</Layout>
