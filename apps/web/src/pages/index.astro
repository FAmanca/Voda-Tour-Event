---
// Voda Tour & Event — Landing Page (index.astro)
// SSR fetch from Directus, then render all sections

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import FeatureStrip from "../components/FeatureStrip.astro";
import SectionHeader from "../components/SectionHeader.astro";
import PackageGrid from "../components/PackageGrid.astro";
import StatsBar from "../components/StatsBar.astro";
import CTABand from "../components/CTABand.astro";

import { getSettings, getDestinations, getPackages, getActivityTypes } from "../lib/directus";
import type { DestinationWithRegion, Package, ActivityType } from "../types/directus";

// -----------------------------------------------------------------------
// SSR fetch dari Directus
// -----------------------------------------------------------------------

let settings: Record<string, string> = {};
let destinations: DestinationWithRegion[] = [];
let packages: Package[] = [];
let activityTypes: ActivityType[] = [];
let fetchError = false;

try {
  settings = await getSettings();
  destinations = await getDestinations("*,region_id.*") as DestinationWithRegion[];
  packages = await getPackages(4) as Package[];
  activityTypes = await getActivityTypes() as ActivityType[];
} catch (e) {
  console.error("SSR fetch error:", e);
  fetchError = true;
}
---

<Layout
  title="Voda Tour & Event | Perjalanan Berkesan, Momen Tak Terlupakan"
  description="Solusi perjalanan wisata, gathering, dan event terbaik. Private tour, corporate gathering, dan outbound dengan pengalaman tak terlupakan."
  active="beranda"
>
  <main>
    <!-- 3.1 Hero + SearchCard -->
    <Hero
      settings={settings}
      destinations={destinations}
      activityTypes={activityTypes}
    />

    <!-- 3.2 FeatureStrip -->
    <FeatureStrip />

    <!-- 3.3 + 3.4 PackageGrid -->
    <section id="paket" class="wrap py-[90px] max-lg:py-[60px]">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-[30px] lg:gap-[40px] items-start">
        <div>
          <SectionHeader
            eyebrow="PAKET PILIHAN"
            title="Destinasi & Paket Favorit"
            description="Temukan paket perjalanan dan event terbaik untuk momen spesial Anda."
            layout="default"
          />
        </div>
        <div class="lg:col-span-4">
          {fetchError ? (
            <div class="rounded-[var(--radius-md)] bg-red-50 border border-red-200 p-[16px] text-red-700 text-[14px]">
              <i class="fa-solid fa-circle-exclamation mr-[8px]"></i>
              Gagal memuat data. Pastikan Directus sudah berjalan.
            </div>
          ) : (
            <PackageGrid packages={packages} />
          )}
        </div>
      </div>
    </section>

    <!-- 3.5 StatsBar + Testimonial -->
    <StatsBar />

    <!-- 3.6 CTABand -->
    <CTABand
      ctaLabel="Konsultasi Gratis"
      ctaUrl={`https://wa.me/${settings.wa_number || settings.whatsapp || "6282112345678"}?text=Halo%20Voda%20Tour%20%26%20Event%2C%20saya%20ingin%20tahu%20lebih%20lanjut%20tentang%20paket%20Anda.`}
    />
  </main>
</Layout>
