---
import Layout from "../layouts/Layout.astro";
import Eyebrow from "../components/Eyebrow.astro";
import { getDestinations, getRegions, getAssetUrl } from "../lib/directus";
import type { DestinationWithRegion, Region } from "../types/directus";

const DIRECTUS_URL = import.meta.env.DIRECTUS_URL || "http://localhost:8055";

let destinations: DestinationWithRegion[] = [];
let regions: Region[] = [];
let fetchError = false;

const pageParam = Astro.url.searchParams.get("page") || "1";
let currentPage = parseInt(pageParam, 10);
if (isNaN(currentPage) || currentPage < 1) currentPage = 1;
const limit = 9;
let totalDestinations = 0;
let totalPages = 1;

// Grab region from URL for optional filtering
const regionFilter = Astro.url.searchParams.get("region") || "";

try {
  let destUrl = `${DIRECTUS_URL}/items/destinations?fields=*,region_id.*&filter[status][_eq]=published&sort=name&limit=${limit}&page=${currentPage}&meta=filter_count`;
  if (regionFilter) {
    // Note: URL encoding filter json is important for Directus
    destUrl += `&filter[region_id][slug][_eq]=${encodeURIComponent(regionFilter)}`;
  }

  const [destRes, regionsList] = await Promise.all([
    fetch(destUrl),
    getRegions()
  ]);

  if (destRes.ok) {
    const json = await destRes.json();
    destinations = (json.data || []) as DestinationWithRegion[];
    totalDestinations = json.meta?.filter_count || 0;
    totalPages = Math.ceil(totalDestinations / limit);
  }

  regions = regionsList;
} catch {
  fetchError = true;
}
---

<Layout title="Destinasi Wisata | Voda Tour & Event" description="Jelajahi destinasi wisata terbaik." active="destinasi">
  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0A3B52] via-navy-700 to-navy-800 py-[90px] max-lg:py-[60px]">
      <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0); background-size: 30px 30px;" aria-hidden="true"></div>
      <svg class="absolute bottom-0 left-0 right-0 text-white" viewBox="0 0 1440 48" preserveAspectRatio="none" aria-hidden="true"><path d="M0 48V24l120-8 180 16 240-20 200 10 300-24 200 18V48Z" fill="currentColor" opacity="0.06"/></svg>
      <div class="wrap relative z-10">
        <div class="max-w-[600px]">
          <Eyebrow text="Destinasi" />
          <h1 class="font-[family-name:var(--font-display)] text-white text-[42px] max-lg:text-[30px] font-bold mt-[14px] leading-tight">
            Jelajahi <span class="text-orange-400">Destinasi</span> Pilihan
          </h1>
          <p class="text-white/65 text-[16px] max-lg:text-[14px] mt-[10px] leading-relaxed">
            Temukan pengalaman tak terlupakan di berbagai destinasi terbaik.
          </p>
          <div class="flex flex-wrap gap-[12px] mt-[28px]">
            {regions.map((region) => (
              <a href={"?region=" + region.slug} class="inline-flex items-center gap-[5px] bg-white/10 hover:bg-white/20 text-white text-[12.5px] font-medium px-[14px] py-[6px] rounded-full no-underline transition-all backdrop-blur-sm border border-white/10">
                <i class="fa-solid fa-location-dot text-orange-400 text-[9px]"></i>{region.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    {fetchError && (
      <section class="py-[80px]"><div class="wrap text-center">
        <div class="max-w-[400px] mx-auto bg-red-50 border border-red-200 rounded-[var(--radius-lg)] p-[30px]">
          <i class="fa-solid fa-circle-exclamation text-[36px] text-red-400 block mb-[12px]"></i>
          <p class="text-red-700 text-[14px] font-medium">Gagal memuat destinasi.</p>
        </div>
      </div></section>
    )}

    {!fetchError && (
      <section class="py-[70px] max-lg:py-[50px]"><div class="wrap">
        {destinations.length > 0 ? (
          <>
            <div class="flex items-center justify-between mb-[28px]">
              <p class="text-navy-500 text-[13px]"><strong class="text-navy-800">{totalDestinations}</strong> destinasi tersedia</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[28px]">
              {destinations.map((destination, index) => {
                const regionName = destination.region_id?.name || "";
                const imgUrl = destination.image
                  ? getAssetUrl(destination.image, { width: 600, height: 400, format: "webp", quality: 80 })
                  : null;
                const isLcp = index === 0;
                return (
                  <a href={"/destinasi/" + destination.slug} class="group block bg-white rounded-[var(--radius-lg)] shadow-[var(--shadow-soft)] overflow-hidden no-underline hover:shadow-[0_12px_32px_rgba(0,0,0,0.1)] transition-all duration-300 hover:-translate-y-[6px]">
                    <div class="relative aspect-[4/3] overflow-hidden bg-navy-100">
                      {imgUrl ? (
                        <img src={imgUrl} alt={destination.name} class="absolute inset-0 w-full h-full object-cover transition-all duration-500 group-hover:scale-110" loading={isLcp ? "eager" : "lazy"} fetchpriority={isLcp ? "high" : "auto"} />
                      ) : (
                        <div class="absolute inset-0 flex flex-col items-center justify-center text-navy-300">
                          <i class="fa-regular fa-image text-[36px]"></i>
                          <span class="text-[11px] mt-[6px] font-medium">No Image</span>
                        </div>
                      )}
                      {regionName && (
                        <span class="absolute top-[12px] left-[12px] bg-white/90 backdrop-blur-sm text-navy-700 text-[11px] font-semibold px-[10px] py-[3px] rounded-full shadow-sm">
                          <i class="fa-solid fa-location-dot text-orange-500 text-[9px] mr-[3px]"></i>{regionName}
                        </span>
                      )}
                    </div>
                    <div class="p-[20px]">
                      <h3 class="font-[family-name:var(--font-display)] text-navy-800 text-[16px] font-semibold group-hover:text-orange-600 transition-colors">{destination.name}</h3>
                      {destination.description && <p class="text-navy-500 text-[13px] leading-relaxed mt-[4px] line-clamp-2">{destination.description}</p>}
                      <div class="flex items-center gap-[8px] mt-[14px] text-[12px] text-orange-600 font-medium">
                        <span>Lihat Paket</span>
                        <i class="fa-solid fa-arrow-right text-[10px]"></i>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>

            {/* Pagination UI */}
            {totalPages > 1 && (
              <div class="flex justify-center items-center gap-[8px] mt-[40px]">
                {currentPage > 1 ? (
                  <a href={`?page=${currentPage - 1}${regionFilter ? '&region=' + regionFilter : ''}`} class="w-[40px] h-[40px] rounded-full flex items-center justify-center bg-white border border-navy-200 text-navy-600 hover:border-orange-500 hover:text-orange-500 hover:bg-orange-50 transition-all">
                    <i class="fa-solid fa-chevron-left text-[12px]"></i>
                  </a>
                ) : (
                  <span class="w-[40px] h-[40px] rounded-full flex items-center justify-center bg-slate-50 border border-slate-200 text-slate-300 cursor-not-allowed">
                    <i class="fa-solid fa-chevron-left text-[12px]"></i>
                  </span>
                )}
                
                {Array.from({ length: totalPages }).map((_, i) => {
                  const p = i + 1;
                  if (
                    totalPages <= 5 || 
                    p === 1 || p === totalPages || 
                    (p >= currentPage - 1 && p <= currentPage + 1)
                  ) {
                    return (
                      <a href={`?page=${p}${regionFilter ? '&region=' + regionFilter : ''}`} class={`w-[40px] h-[40px] rounded-full flex items-center justify-center text-[14px] font-semibold transition-all ${p === currentPage ? 'bg-orange-500 text-white shadow-lg shadow-orange-500/30' : 'bg-white border border-navy-200 text-navy-600 hover:border-orange-500 hover:text-orange-500 hover:bg-orange-50'}`}>
                        {p}
                      </a>
                    );
                  } else if (p === currentPage - 2 || p === currentPage + 2) {
                    return <span class="text-navy-300">...</span>;
                  }
                  return null;
                })}

                {currentPage < totalPages ? (
                  <a href={`?page=${currentPage + 1}${regionFilter ? '&region=' + regionFilter : ''}`} class="w-[40px] h-[40px] rounded-full flex items-center justify-center bg-white border border-navy-200 text-navy-600 hover:border-orange-500 hover:text-orange-500 hover:bg-orange-50 transition-all">
                    <i class="fa-solid fa-chevron-right text-[12px]"></i>
                  </a>
                ) : (
                  <span class="w-[40px] h-[40px] rounded-full flex items-center justify-center bg-slate-50 border border-slate-200 text-slate-300 cursor-not-allowed">
                    <i class="fa-solid fa-chevron-right text-[12px]"></i>
                  </span>
                )}
              </div>
            )}
          </>
        ) : (
          <div class="text-center py-[80px]">
            <i class="fa-regular fa-map text-[56px] text-navy-200 block mb-[16px]"></i>
            <h3 class="font-[family-name:var(--font-display)] text-navy-600 text-[20px] font-semibold">Belum Ada Destinasi</h3>
            <p class="text-navy-400 text-[14px] mt-[6px]">Destinasi akan segera ditambahkan.</p>
          </div>
        )}
      </div></section>
    )}
  </main>
</Layout>