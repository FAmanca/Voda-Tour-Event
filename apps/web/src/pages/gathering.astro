---
import Layout from "../layouts/Layout.astro";
import PackageCard from "../components/PackageCard.astro";
import Eyebrow from "../components/Eyebrow.astro";
import CTABand from "../components/CTABand.astro";

const U = import.meta.env.DIRECTUS_URL || "http://localhost:8055";
let packages = [];
let err = false;

try {
  const ar = await fetch(U + "/items/activity_types?filter[slug][_eq]=corporate-gathering");
  let aid = "";
  if (ar.ok) { const aj = await ar.json(); aid = aj.data?.[0]?.id || ""; }
  if (aid) {
    const jr = await fetch(U + "/items/packages_activity_types?fields=package_id&filter[activity_type_id][_eq]=" + aid);
    let ids = [];
    if (jr.ok) { const jj = await jr.json(); ids = (jj.data || []).map((x) => x.package_id); }
    if (ids.length > 0) {
      const pr = await fetch(U + "/items/paket?fields=*,destination_id.*&filter[id][_in]=" + ids.join(",") + "&filter[status][_eq]=published&sort=-id");
      if (pr.ok) { const pj = await pr.json(); packages = pj.data || []; }
    }
  }
} catch { err = true; }
---

<Layout title="Gathering & Event | Voda Tour & Event" description="Solusi gathering perusahaan, outbound, team building." active="gathering">
  <main>
    <section class="relative min-h-[400px] flex items-center overflow-hidden bg-navy-900">
      <div class="absolute inset-0 bg-gradient-to-r from-[rgba(10,59,82,0.95)] to-[rgba(10,59,82,0.85)]"></div>
      <div class="wrap relative z-10 text-center py-[80px] max-lg:py-[50px]">
        <Eyebrow text="Gathering & Event" />
        <h1 class="font-[family-name:var(--font-display)] text-white text-[38px] max-lg:text-[28px] font-bold mt-[12px]">Acara Perusahaan Jadi Lebih Berkesan</h1>
        <p class="text-white/70 text-[16px] max-lg:text-[14px] mt-[12px] max-w-[550px] mx-auto">Dari outbound seru hingga gathering elegan.</p>
        <div class="flex flex-wrap justify-center gap-[30px] mt-[40px]">
          <div class="text-center"><div class="w-[48px] h-[48px] mx-auto rounded-full bg-white/10 flex items-center justify-center text-orange-500 text-[20px]"><i class="fa-solid fa-people-group"></i></div><p class="text-white/70 text-[12px] mt-[8px]">Team Building</p></div>
          <div class="text-center"><div class="w-[48px] h-[48px] mx-auto rounded-full bg-white/10 flex items-center justify-center text-orange-500 text-[20px]"><i class="fa-solid fa-chalkboard-user"></i></div><p class="text-white/70 text-[12px] mt-[8px]">Outbound</p></div>
          <div class="text-center"><div class="w-[48px] h-[48px] mx-auto rounded-full bg-white/10 flex items-center justify-center text-orange-500 text-[20px]"><i class="fa-solid fa-utensils"></i></div><p class="text-white/70 text-[12px] mt-[8px]">Company Gathering</p></div>
          <div class="text-center"><div class="w-[48px] h-[48px] mx-auto rounded-full bg-white/10 flex items-center justify-center text-orange-500 text-[20px]"><i class="fa-solid fa-champagne-glasses"></i></div><p class="text-white/70 text-[12px] mt-[8px]">Corporate Event</p></div>
        </div>
      </div>
    </section>
    {err && <section><div class="wrap py-[60px]"><div class="rounded-[var(--radius-md)] bg-red-50 border border-red-200 p-[20px] text-red-700 text-[14px] text-center"><i class="fa-solid fa-circle-exclamation mr-[8px]"></i>Gagal memuat paket.</div></div></section>}
    {!err && <section><div class="wrap py-[70px] max-lg:py-[50px]">{packages.length > 0 ? <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[24px]">{packages.map((pkg) => <PackageCard package={pkg} showDestination />)}</div> : <div class="text-center py-[60px]"><i class="fa-regular fa-calendar text-[48px] text-navy-300 block mb-[16px]"></i><h3 class="font-[family-name:var(--font-display)] text-navy-600 text-[20px] font-semibold">Belum Ada Paket Gathering</h3><p class="text-navy-400 text-[14px] mt-[8px]">Paket akan segera hadir.</p></div>}</div></section>}
    {!err && packages.length > 0 && <CTABand />}
  </main>
</Layout>
