---
import Layout from "../layouts/Layout.astro";
import PackageCard from "../components/PackageCard.astro";
import { getPackagesByActivityType } from "../lib/directus";
import type { Package } from "../types/directus";

let packages: Package[] = [];
let fetchError = false;

try {
  packages = await getPackagesByActivityType("corporate-gathering");
} catch {
  fetchError = true;
}
---

<Layout title="Gathering & Event | Voda Tour & Event" description="Solusi gathering perusahaan, outbound, team building profesional." active="gathering">
  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-navy-900 via-navy-800 to-navy-950 py-24 max-lg:py-16">
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 40px, #fff 40px, #fff 41px), repeating-linear-gradient(90deg, transparent, transparent 40px, #fff 40px, #fff 41px);" aria-hidden="true"></div>
      <div class="absolute -top-20 -right-10 w-64 h-64 rounded-full bg-orange-500/10 blur-[80px]" aria-hidden="true"></div>
      <div class="absolute -bottom-10 -left-20 w-48 h-48 rounded-full bg-teal-400/10 blur-[60px]" aria-hidden="true"></div>
      <div class="wrap relative z-10 text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-orange-400 text-xs font-semibold px-3.5 py-1.5 rounded-full mb-4">
          <i class="fa-solid fa-people-group"></i>GATHERING &amp; EVENT
        </div>
        <h1 class="font-[family-name:var(--font-display)] text-white text-4xl max-lg:text-3xl font-bold leading-tight">
          Acara Perusahaan Jadi <span class="text-orange-400">Lebih Berkesan</span>
        </h1>
        <p class="text-white/65 text-base max-lg:text-sm mt-3 max-w-xl mx-auto leading-relaxed">
          Dari outbound seru sampai company gathering elegan &mdash; tim profesional siap bikin event Anda tak terlupakan.
        </p>
        <div class="flex flex-wrap justify-center gap-3 mt-8">
          <a href="#paket" class="inline-flex items-center gap-2 bg-orange-600 text-white rounded-full px-6 py-3 font-semibold text-sm no-underline shadow-lg shadow-orange-500/40 transition-all hover:-translate-y-px hover:bg-orange-500">
            Lihat Paket <i class="fa-solid fa-arrow-down"></i>
          </a>
          <a href="/kontak" class="inline-flex items-center gap-2 bg-white/10 text-white rounded-full px-6 py-3 font-semibold text-sm no-underline border border-white/20 transition-all hover:bg-white/20">
            <i class="fa-regular fa-calendar-check"></i>Konsultasi Gratis
          </a>
        </div>
      </div>
    </section>

    <section class="py-16 max-lg:py-12"><div class="wrap">
      <div class="text-center mb-10">
        <span class="text-xs font-semibold text-orange-500 uppercase tracking-widest">Layanan Kami</span>
        <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-2xl max-lg:text-xl font-bold mt-2">Solusi Event untuk Semua Kebutuhan</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/cari?kegiatan=team-building" class="no-underline">
          <div class="bg-navy-50 rounded-[var(--radius-lg)] p-[24px] text-center hover:bg-orange-50 transition-colors group">
            <div class="w-[52px] h-[52px] mx-auto rounded-full bg-navy-800 flex items-center justify-center text-orange-400 text-[22px] group-hover:bg-orange-500 group-hover:text-white transition-all"><i class="fa-solid fa-people-group"></i></div>
            <h3 class="font-[family-name:var(--font-display)] text-navy-700 text-[14px] font-semibold mt-[12px]">Team Building</h3>
            <p class="text-navy-400 text-[12px] mt-[4px]">Games &amp; kerjasama tim</p>
          </div>
        </a>
        <a href="/cari?kegiatan=outbound" class="no-underline">
          <div class="bg-navy-50 rounded-[var(--radius-lg)] p-[24px] text-center hover:bg-orange-50 transition-colors group">
            <div class="w-[52px] h-[52px] mx-auto rounded-full bg-navy-800 flex items-center justify-center text-orange-400 text-[22px] group-hover:bg-orange-500 group-hover:text-white transition-all"><i class="fa-solid fa-person-hiking"></i></div>
            <h3 class="font-[family-name:var(--font-display)] text-navy-700 text-[14px] font-semibold mt-[12px]">Outbound</h3>
            <p class="text-navy-400 text-[12px] mt-[4px]">Aktivitas outdoor seru</p>
          </div>
        </a>
        <a href="/cari?kegiatan=corporate-gathering" class="no-underline">
          <div class="bg-navy-50 rounded-[var(--radius-lg)] p-[24px] text-center hover:bg-orange-50 transition-colors group">
            <div class="w-[52px] h-[52px] mx-auto rounded-full bg-navy-800 flex items-center justify-center text-orange-400 text-[22px] group-hover:bg-orange-500 group-hover:text-white transition-all"><i class="fa-solid fa-utensils"></i></div>
            <h3 class="font-[family-name:var(--font-display)] text-navy-700 text-[14px] font-semibold mt-[12px]">Company Gathering</h3>
            <p class="text-navy-400 text-[12px] mt-[4px]">Acara santai bersama</p>
          </div>
        </a>
        <a href="/cari?kegiatan=corporate-gathering" class="no-underline">
          <div class="bg-navy-50 rounded-[var(--radius-lg)] p-[24px] text-center hover:bg-orange-50 transition-colors group">
            <div class="w-[52px] h-[52px] mx-auto rounded-full bg-navy-800 flex items-center justify-center text-orange-400 text-[22px] group-hover:bg-orange-500 group-hover:text-white transition-all"><i class="fa-solid fa-champagne-glasses"></i></div>
            <h3 class="font-[family-name:var(--font-display)] text-navy-700 text-[14px] font-semibold mt-[12px]">Corporate Event</h3>
            <p class="text-navy-400 text-[12px] mt-[4px]">Event skala besar</p>
          </div>
        </a>
      </div>
    </div></section>

    <section id="paket" class="py-16 max-lg:py-10 bg-navy-50"><div class="wrap">
      {fetchError ? (
        <div class="text-center py-16">
          <i class="fa-solid fa-circle-exclamation text-4xl text-red-400 block mb-3"></i>
          <p class="text-red-600 text-sm font-medium">Gagal memuat paket.</p>
        </div>
      ) : packages.length > 0 ? (
        <>
          <div class="flex items-center justify-between mb-7">
            <div>
              <span class="text-xs font-semibold text-orange-500 uppercase tracking-widest">Paket Gathering</span>
              <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-2xl font-bold mt-1">Pilihan Paket Kami</h2>
            </div>
            <p class="text-navy-400 text-xs"><strong class="text-navy-600">{packages.length}</strong> paket</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7">
            {packages.map((pkg) => <PackageCard package={pkg} showDestination />)}
          </div>
        </>
      ) : (
        <div class="text-center py-20">
          <i class="fa-regular fa-box-open text-6xl text-navy-200 block mb-4"></i>
          <h3 class="font-[family-name:var(--font-display)] text-navy-600 text-xl font-semibold">Belum Ada Paket</h3>
          <p class="text-navy-400 text-sm mt-1.5">Paket gathering akan segera hadir.</p>
        </div>
      )}
    </div></section>

    <section class="py-16"><div class="wrap text-center">
      <h2 class="font-[family-name:var(--font-display)] text-navy-800 text-2xl font-bold">Siap Rencanakan Event?</h2>
      <p class="text-navy-500 text-sm mt-2 max-w-md mx-auto">Tim kami siap bantu dari konsep sampai eksekusi.</p>
      <a href="/kontak" class="inline-flex items-center gap-2 mt-5 bg-orange-600 text-white rounded-full px-7 py-3 font-semibold text-sm no-underline shadow-lg shadow-orange-500/40 transition-all hover:-translate-y-0.5 hover:bg-orange-500">
        <i class="fa-brands fa-whatsapp"></i>Hubungi Via WA
      </a>
    </div></section>
  </main>
</Layout>