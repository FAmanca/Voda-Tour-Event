---
import Layout from "../layouts/Layout.astro";
import Eyebrow from "../components/Eyebrow.astro";
import GallerySection from "../components/GallerySection.astro";

const U = import.meta.env.DIRECTUS_URL || "http://localhost:8055";
let imgs = [];
let err = false;
try {
  const [dr, pr] = await Promise.all([
    fetch(U + "/items/destinasi?fields=gallery,image&filter[status][_eq]=published"),
    fetch(U + "/items/paket?fields=gallery&filter[status][_eq]=published"),
  ]);
  if (dr.ok) { const j = await dr.json(); (j.data || []).forEach((d) => { if (d.image) imgs.push(d.image); if (d.gallery) d.gallery.forEach((g) => imgs.push(g)); }); }
  if (pr.ok) { const j = await pr.json(); (j.data || []).forEach((p) => { if (p.gallery) p.gallery.forEach((g) => imgs.push(g)); }); }
  imgs = [...new Set(imgs)];
} catch { err = true; }
---

<Layout title="Galeri Foto | Voda Tour & Event" description="Galeri foto destinasi dan event." active="galeri">
  <main>
    <section class="bg-navy-900 py-[80px] max-lg:py-[50px]"><div class="wrap text-center"><Eyebrow text="Galeri" /><h1 class="font-[family-name:var(--font-display)] text-white text-[38px] max-lg:text-[28px] font-bold mt-[12px]">Galeri Foto</h1><p class="text-white/70 text-[16px] max-lg:text-[14px] mt-[10px] max-w-[500px] mx-auto">Momen-momen terbaik dari perjalanan dan event kami.</p></div></section>
    {err && <section><div class="wrap py-[60px]"><div class="rounded-[var(--radius-md)] bg-red-50 border border-red-200 p-[20px] text-red-700 text-[14px] text-center"><i class="fa-solid fa-circle-exclamation mr-[8px]"></i>Gagal memuat galeri.</div></div></section>}
    {!err && <section><div class="wrap py-[60px] max-lg:py-[40px]">{imgs.length > 0 ? <GallerySection images={imgs} columns={4} /> : <div class="text-center py-[60px]"><i class="fa-regular fa-image text-[48px] text-navy-300 block mb-[16px]"></i><p class="text-navy-500 text-[16px]">Belum ada galeri tersedia.</p></div>}</div></section>}
  </main>
</Layout>
