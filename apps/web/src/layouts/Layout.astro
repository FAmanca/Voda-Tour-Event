---
// Voda Tour & Event — Base Layout
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PopupAd from "../components/PopupAd.astro";
import { getSettings } from "../lib/directus";

import { DEFAULT_WA_NUMBER } from "../lib/constants";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  jsonld?: string;
  active?: 'beranda' | 'paket' | 'gathering' | 'destinasi' | 'tentang' | 'kontak';
}

const {
  title = "Voda Tour & Event",
  description = "Perjalanan Berkesan, Momen Tak Terlupakan",
  image = "",
  canonical = "",
  jsonld = "",
  active,
} = Astro.props;

let settings: Record<string, string> = {};
try {
  settings = await getSettings();
} catch {}

const siteUrl = "https://vodatrip.id";
const waNum = settings.wa_number || settings.whatsapp || DEFAULT_WA_NUMBER;
const defaultImage = siteUrl + "/images/VodaTravelIcon.webp";
const ogImage = image || defaultImage;

const currentPath = Astro.url.pathname === '/' ? '' : Astro.url.pathname.replace(/\/$/, '');
const autoCanonical = canonical || (siteUrl + currentPath);

// Fetch Google Tag Manager ID dynamically
const gtmId = (typeof process !== 'undefined' ? process.env.PUBLIC_GTM_ID : undefined) || import.meta.env.PUBLIC_GTM_ID || settings.gtm_id || settings.google_tag_manager_id;
---

<!doctype html>
<html lang="id">
  <head>
    <!-- Google Tag Manager -->
    {gtmId && (
      <script is:inline define:vars={{ gtmId }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0B2340" />

    <!-- LCP Preload -->
    <link rel="preload" as="image" href="/images/beach-1920.avif" type="image/avif" media="(min-width: 769px)" fetchpriority="high" />
    <link rel="preload" as="image" href="/images/beach-768.avif" type="image/avif" media="(min-width: 481px) and (max-width: 768px)" fetchpriority="high" />
    <link rel="preload" as="image" href="/images/beach-480.avif" type="image/avif" media="(max-width: 480px)" fetchpriority="high" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={autoCanonical} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="id_ID" />
  <meta property="og:site_name" content="Voda Tour & Event" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Canonical -->
  <link rel="canonical" href={autoCanonical} />


    <!-- Google Fonts (Optimized Async) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&family=Playfair+Display:ital@1&family=Inter:wght@400;600&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&family=Playfair+Display:ital@1&family=Inter:wght@400;600&display=swap" />
    </noscript>

    <!-- Font Awesome 6 (async, non-blocking) -->
    <link
      rel="preload"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
      crossorigin="anonymous"
    />
    <noscript>
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
    </noscript>
    <!-- JSON-LD Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Voda Tour & Event",
    "url": "https://vodatrip.id",
    "logo": "https://vodatrip.id/images/VodaTravelIcon.webp",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": settings.phone ? "+62-" + settings.phone.replace(/^62/, '') : "+62-821-1234-5678",
      "contactType": "customer service",
      "availableLanguage": ["Indonesia", "English"]
    },
    "sameAs": [
      `https://facebook.com/${settings.facebook || 'voda.event'}`,
      `https://youtube.com/${settings.youtube || '@vodatrip'}`,
      `https://instagram.com/${settings.instagram || 'voda.event'}`,
      `https://tiktok.com/${settings.tiktok || '@voda.event'}`,
      `https://threads.net/${settings.threads || '@voda.event'}`,
      `https://x.com/${settings.x || 'voda_event'}`,
      `https://wa.me/${waNum}`
    ]
  })}></script>

    {jsonld && <script type="application/ld+json" set:html={jsonld}></script>}
</head>
  <body class="pt-[88px] max-lg:pt-[76px]">
    <!-- Google Tag Manager (noscript) -->
    {gtmId && (
      <noscript>
        <iframe 
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0" 
          width="0" 
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}
    <!-- End Google Tag Manager (noscript) -->
    <!-- Skip to Content Link for Accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:bg-orange-600 focus:text-white focus:px-6 focus:py-3 focus:rounded-[8px] focus:shadow-lg focus:text-[14px] focus:font-semibold focus:outline-none focus:ring-2 focus:ring-orange-400">
      Langsung ke konten utama
    </a>

    <Header {active} {settings} />
    <div id="main-content">
      <slot />
    </div>
    <Footer {settings} />
    <PopupAd />
  </body>
</html>
