# ===============================================================================
# Voda Tour & Event — Astro Frontend Environment Variables
# Copy ke .env sebelum menjalankan dev server.
# ===============================================================================

# URL Directus (tanpa trailing slash)
DIRECTUS_URL=http://localhost:8055

# Site URL (untuk SEO canonical & sitemap)
SITE_URL=http://localhost:4321

# Public URL untuk assets (sama dengan DIRECTUS_URL di dev)
ASSETS_URL=http://localhost:8055

# Google Tag Manager Container ID
PUBLIC_GTM_ID=
