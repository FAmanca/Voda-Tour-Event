# =======================================================
# VODA TOUR & EVENT - PRODUCTION ENVIRONMENT VARIABLES
# Copy this file to .env.prod and update the values
# =======================================================

# -------------------------------------------------------
# POSTGRES DATABASE
# -------------------------------------------------------
POSTGRES_USER=voda_admin
POSTGRES_PASSWORD=generate_a_secure_password_here
POSTGRES_DB=voda_travel_prod

# -------------------------------------------------------
# DIRECTUS CMS
# -------------------------------------------------------
# Keys for JWT and telemetry (Generate secure random strings)
DIRECTUS_KEY=generate_a_random_uuid_for_key
DIRECTUS_SECRET=generate_a_random_secret_string_here

# Initial Admin User
DIRECTUS_ADMIN_EMAIL=admin@vodaevent.id
DIRECTUS_ADMIN_PASSWORD=change_this_admin_password

# CORS Settings
CORS_ORIGIN=https://vodaevent.id,https://www.vodaevent.id

# Storage (R2 S3 Configuration)
# Uncomment and configure these when moving to Cloudflare R2
# STORAGE_LOCATIONS=s3
# STORAGE_S3_DRIVER=s3
# STORAGE_S3_KEY=your_cloudflare_r2_access_key
# STORAGE_S3_SECRET=your_cloudflare_r2_secret_key
# STORAGE_S3_BUCKET=your_r2_bucket_name
# STORAGE_S3_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
# STORAGE_S3_REGION=auto

# -------------------------------------------------------
# ASTRO WEB APP
# -------------------------------------------------------
# Note: Astro needs this URL at build time if it performs SSR fetches.
# Since we use docker-compose, 'http://directus:8055' resolves internally.
DIRECTUS_URL=http://directus:8055
