# ==============================================================================
# Voda Tour & Event — Infrastructure Environment Variables
# Source of Truth untuk semua env variable di project ini.
# Copy file ini ke .env dan isi sesuai environment (local/staging/production).
# ==============================================================================
#
# Cara pakai:
#   cp .env.example .env
#   docker compose --env-file .env up -d
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_USER=voda
POSTGRES_PASSWORD=voda123
POSTGRES_DB=voda_travel
DB_PORT=5432

# ------------------------------------------------------------------------------
# Directus
# ------------------------------------------------------------------------------
DIRECTUS_PORT=8055
DIRECTUS_ADMIN_EMAIL=admin@vodatrip.id
DIRECTUS_ADMIN_PASSWORD=admin123
DIRECTUS_KEY=voda-directus-key-change-in-production
DIRECTUS_SECRET=voda-directus-secret-change-in-production

# ------------------------------------------------------------------------------
# File Storage — Local (development)
# ------------------------------------------------------------------------------
STORAGE_LOCATIONS=local
STORAGE_LOCAL_DRIVER=local
STORAGE_LOCAL_ROOT=/directus/uploads

# ------------------------------------------------------------------------------
# File Storage — Cloudflare R2 (production) — UNCOMMENT SAAT DEPLOY
# ------------------------------------------------------------------------------
# STORAGE_LOCATIONS=s3
# STORAGE_S3_DRIVER=s3
# STORAGE_S3_KEY=your-r2-access-key-id
# STORAGE_S3_SECRET=your-r2-secret-access-key
# STORAGE_S3_BUCKET=voda-tour-event-images
# STORAGE_S3_REGION=auto
# STORAGE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ------------------------------------------------------------------------------
# CORS — Izinkan origin frontend
# ------------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:4321,http://localhost:5173
